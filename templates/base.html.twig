<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}InApp Inventory Dashboard{% endblock %}</title>

    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
    <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('inapp/assets/images/apple-touch-icon.png') }}">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('inapp/assets/images/favicon-32x32.png') }}">
    <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('inapp/assets/images/favicon-16x16.png') }}">
    <link rel="manifest" href="{{ asset('inapp/assets/site.webmanifest') }}">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">

    {% block stylesheets %}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css">
        <link rel="stylesheet" crossorigin href="/styles/app.css">
        <style>
            :root {
                --sidebar-width: 260px;
                --navbar-height: 70px;
            }
            body {
                background-color: #f8f9fa;
                margin: 0;
                overflow-x: hidden;
            }
            #content, .content {
                margin-left: var(--sidebar-width);
                padding-top: var(--navbar-height);
                min-height: 100vh;
                transition: all 0.3s ease;
            }
            body > .container-fluid {
                margin-left: var(--sidebar-width);
                padding-top: calc(var(--navbar-height) + 1.5rem);
                padding-left: 2rem;
                padding-right: 2rem;
                min-height: 100vh;
                max-width: 100%;
            }
            @media (max-width: 992px) {
                #content, .content, body > .container-fluid {
                    margin-left: 0;
                }
            }

            /* ===== DARK MODE ===== */
            [data-theme="dark"] body,
            body[data-theme="dark"] { background: #1a1a2e !important; color: #e0e0e0 !important; }
            [data-theme="dark"] .card,
            body[data-theme="dark"] .card { background: #16213e !important; border-color: #2d2d4e !important; color: #e0e0e0 !important; }
            body[data-theme="dark"] #topbar,
            body[data-theme="dark"] .navbar { background: #16213e !important; border-color: #2d2d4e !important; }
            body[data-theme="dark"] #sidebar,
            body[data-theme="dark"] .sidebar { background: #0f3460 !important; }
            body[data-theme="dark"] .bg-white { background: #16213e !important; }
            body[data-theme="dark"] .border-bottom { border-color: #2d2d4e !important; }
            body[data-theme="dark"] .text-dark { color: #e0e0e0 !important; }
            body[data-theme="dark"] .text-secondary { color: #a0a0b0 !important; }
            body[data-theme="dark"] .form-control,
            body[data-theme="dark"] .form-select { background: #1a1a2e !important; color: #e0e0e0 !important; border-color: #2d2d4e !important; }
            body[data-theme="dark"] .dropdown-menu { background: #16213e !important; border-color: #2d2d4e !important; }
            body[data-theme="dark"] .dropdown-item { color: #e0e0e0 !important; }
            body[data-theme="dark"] .dropdown-item:hover { background: #0f3460 !important; }
            body[data-theme="dark"] .list-group-item { background: #16213e !important; border-color: #2d2d4e !important; color: #e0e0e0 !important; }
            body[data-theme="dark"] .table { color: #e0e0e0 !important; }
            body[data-theme="dark"] .table td,
            body[data-theme="dark"] .table th { border-color: #2d2d4e !important; }
            body[data-theme="dark"] .btn-light { background: #2d2d4e !important; border-color: #2d2d4e !important; color: #e0e0e0 !important; }
            body[data-theme="dark"] .card-header { background: #16213e !important; border-color: #2d2d4e !important; }
            body[data-theme="dark"] h1,body[data-theme="dark"] h2,body[data-theme="dark"] h3,
            body[data-theme="dark"] h4,body[data-theme="dark"] h5,body[data-theme="dark"] h6 { color: #e0e0e0 !important; }
            body[data-theme="dark"] small, body[data-theme="dark"] .small { color: #a0a0b0 !important; }
        </style>
    {% endblock %}
    <meta name="csrf-token" content="{{ csrf_token('archive') }}">
</head>
<body data-theme="{{ app.user ? app.user.theme : 'light' }}">
    <div id="overlay" class="overlay"></div>
    {{ include('admin/partials/navbar.html.twig') }}
    {{ include('admin/partials/sidebar.html.twig') }}

    {% block body %}{% endblock %}

    {% block javascripts %}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        <script src="{{ asset('inapp/assets/js/main.js') }}"></script>
        {% if app.user %}
        <script>
        document.addEventListener('DOMContentLoaded', function() {
            const btn = document.getElementById('theme-toggle');
            if (!btn) return;
            btn.addEventListener('click', function() {
                const body = document.body;
                const current = body.getAttribute('data-theme') || 'light';
                const next = current === 'light' ? 'dark' : 'light';
                body.setAttribute('data-theme', next);
                const icon = document.getElementById('theme-icon');
                if (icon) { icon.className = next === 'dark' ? 'ti ti-sun' : 'ti ti-moon'; }
                fetch('{{ path('app_theme_toggle') }}', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                    body: 'theme=' + next
                });
            });
        });
        </script>
        {% endif %}
    {% endblock %}
</body>
</html>