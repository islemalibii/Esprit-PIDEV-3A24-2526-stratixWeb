{% extends 'admin/base_admin.html.twig' %}

{% block title %}Dashboard — Stratix{% endblock %}

{% block admin_content %}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold mb-0" style="font-size:1.8rem;">Dashboard</h1>
        <p class="text-secondary mb-0" style="font-size:.95rem;">{{ "now"|date("d/m/Y") }} — Bienvenue, {{ app.user.prenom }} 👋</p>
    </div>
    <a href="{{ path('admin_user_new') }}" class="btn btn-primary">
        <i class="ti ti-plus me-1"></i> Nouvel utilisateur
    </a>
</div>

{# ── STAT CARDS ── #}
<div class="row g-3 mb-4">
    <div class="col-lg-3 col-sm-6">
        <div class="card p-4 bg-primary bg-opacity-10 border border-primary border-opacity-25 rounded-2 h-100">
            <div class="d-flex gap-3 align-items-center">
                <div class="icon-shape icon-md bg-primary text-white rounded-2 d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                    <i class="ti ti-users fs-4"></i>
                </div>
                <div>
                    <div class="text-secondary small">Total utilisateurs</div>
                    <div class="fw-bold fs-3 lh-1">{{ stats.total }}</div>
                </div>
            </div>
            <div class="progress mt-3" style="height:4px;">
                <div class="progress-bar bg-primary" style="width:100%"></div>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-sm-6">
        <div class="card p-4 bg-success bg-opacity-10 border border-success border-opacity-25 rounded-2 h-100">
            <div class="d-flex gap-3 align-items-center">
                <div class="icon-shape icon-md bg-success text-white rounded-2 d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                    <i class="ti ti-user-check fs-4"></i>
                </div>
                <div>
                    <div class="text-secondary small">Comptes actifs</div>
                    <div class="fw-bold fs-3 lh-1">{{ stats.actifs }}</div>
                </div>
            </div>
            <div class="progress mt-3" style="height:4px;">
                <div class="progress-bar bg-success" style="width:{{ stats.taux_actifs }}%"></div>
            </div>
            <div class="text-success small mt-1">{{ stats.taux_actifs }}% du total</div>
        </div>
    </div>
    <div class="col-lg-3 col-sm-6">
        <div class="card p-4 bg-danger bg-opacity-10 border border-danger border-opacity-25 rounded-2 h-100">
            <div class="d-flex gap-3 align-items-center">
                <div class="icon-shape icon-md bg-danger text-white rounded-2 d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                    <i class="ti ti-lock fs-4"></i>
                </div>
                <div>
                    <div class="text-secondary small">Verrouillés</div>
                    <div class="fw-bold fs-3 lh-1">{{ stats.locked }}</div>
                </div>
            </div>
            <div class="progress mt-3" style="height:4px;">
                <div class="progress-bar bg-danger" style="width:{{ stats.total > 0 ? (stats.locked/stats.total*100)|round : 0 }}%"></div>
            </div>
            <div class="text-danger small mt-1">{{ stats.total > 0 ? (stats.locked/stats.total*100)|round : 0 }}% du total</div>
        </div>
    </div>
    <div class="col-lg-3 col-sm-6">
        <div class="card p-4 bg-info bg-opacity-10 border border-info border-opacity-25 rounded-2 h-100">
            <div class="d-flex gap-3 align-items-center">
                <div class="icon-shape icon-md bg-info text-white rounded-2 d-flex align-items-center justify-content-center" style="width:48px;height:48px;">
                    <i class="fas fa-envelope fs-4"></i>
                </div>
                <div>
                    <div class="text-secondary small">Emails envoyés</div>
                    <div class="fw-bold fs-3 lh-1">{{ emailNotifications|length }}</div>
                </div>
            </div>
            <div class="progress mt-3" style="height:4px;">
                <div class="progress-bar bg-info" style="width:100%"></div>
            </div>
            <div class="text-info small mt-1">Notifications récentes</div>
        </div>
    </div>
</div>

{# ── SECTION NOTIFICATIONS ── #}
<div class="card mb-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center px-4 py-3">
        <h4 class="mb-0 h6 fw-bold">
            <i class="fas fa-bell me-2 text-warning"></i> 🔔 Notifications
        </h4>
        <button onclick="sendTestNotification()" class="btn btn-sm btn-outline-primary">
            <i class="fas fa-paper-plane me-1"></i> Tester
        </button>
    </div>
    <div class="card-body px-0 py-0" id="notificationsContainer">
        <div class="text-center text-secondary py-4">
            <i class="fas fa-spinner fa-spin"></i> Chargement...
        </div>
    </div>
</div>

{# ── SECTION BADGES ── #}
<div class="card mb-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center px-4 py-3">
        <h4 class="mb-0 h6 fw-bold">
            <i class="fas fa-trophy me-2 text-warning"></i> 🏆 Mes Badges
        </h4>
        <button onclick="checkBadges()" class="btn btn-sm btn-outline-warning">
            <i class="fas fa-sync-alt me-1"></i> Vérifier
        </button>
    </div>
    <div class="card-body" id="badgesContainer">
        <div class="text-center text-secondary py-4">
            <i class="fas fa-spinner fa-spin"></i> Chargement...
        </div>
    </div>
</div>

{# ── RÉPARTITION PAR RÔLE ── #}
<div class="row g-3 mb-4">
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header bg-white px-4 py-3">
                <h4 class="mb-0 h6 fw-bold">Répartition par rôle</h4>
            </div>
            <div class="card-body px-4">
                {% set roleColors = {
                    'admin': 'primary', 'ceo': 'danger', 'employe': 'info',
                    'responsable_rh': 'success', 'responsable_projet': 'purple',
                    'responsable_production': 'warning'
                } %}
                {% set total = stats.total %}
                {% for role, count in roles %}
                    {% set rc = roleColors[role] ?? 'secondary' %}
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="small fw-semibold">{{ role|upper }}</span>
                            <span class="small text-secondary">{{ count }} ({{ total > 0 ? (count/total*100)|round : 0 }}%)</span>
                        </div>
                        <div class="progress" style="height:6px;border-radius:4px;">
                            <div class="progress-bar bg-{{ rc }}" style="width:{{ total > 0 ? (count/total*100)|round : 0 }}%"></div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    {# ── COMPTES VERROUILLÉS ── #}
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center px-4 py-3">
                <h4 class="mb-0 h6 fw-bold">Comptes verrouillés</h4>
                <span class="badge bg-danger-subtle text-danger border border-danger border-opacity-25">{{ stats.locked }}</span>
            </div>
            {% if lockedUsers|length > 0 %}
            <ul class="list-group list-group-flush">
                {% for u in lockedUsers %}
                <li class="list-group-item d-flex align-items-center gap-3 px-4">
                    <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0"
                         style="width:34px;height:34px;font-size:.75rem;background:linear-gradient(135deg,#dc2626,#ef4444);">
                        {{ u.prenom|first|upper }}{{ u.nom|first|upper }}
                    </div>
                    <div class="flex-grow-1">
                        <div class="fw-semibold small">{{ u.nom }} {{ u.prenom }}</div>
                        <div class="text-secondary" style="font-size:.75rem;">{{ u.failedLoginAttempts ?? 0 }} tentatives</div>
                    </div>
                    <form method="post" action="{{ path('admin_user_toggle_lock', {id: u.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('toggle'~u.id) }}">
                        <button type="submit" class="btn btn-sm btn-outline-success py-0 px-2" style="font-size:.75rem;">
                            Déverrouiller
                        </button>
                    </form>
                </li>
                {% endfor %}
            </ul>
            {% else %}
            <div class="card-body text-center text-secondary small py-4">
                <i class="ti ti-lock-open fs-2 d-block mb-2 text-success"></i>
                Aucun compte verrouillé
            </div>
            {% endif %}
        </div>
    </div>

    {# ── ACTIVITÉ RÉCENTE ── #}
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header bg-white px-4 py-3">
                <h4 class="mb-0 h6 fw-bold">Activité récente</h4>
            </div>
            <ul class="list-group list-group-flush">
                {% for u in recent|slice(0,5) %}
                <li class="list-group-item d-flex align-items-center gap-3 px-4">
                    <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0"
                         style="width:34px;height:34px;font-size:.75rem;background:linear-gradient(135deg,#4f46e5,#7c3aed);">
                        {{ u.prenom|first|upper }}{{ u.nom|first|upper }}
                    </div>
                    <div class="flex-grow-1">
                        <div class="fw-semibold small">{{ u.nom }} {{ u.prenom }}</div>
                        <div class="text-secondary" style="font-size:.75rem;">{{ u.email }}</div>
                    </div>
                    {% set roleColors = {'admin':'primary','ceo':'danger','employe':'info','responsable_rh':'success','responsable_projet':'purple','responsable_production':'warning'} %}
                    {% set rc = roleColors[u.role] ?? 'secondary' %}
                    <span class="badge bg-{{ rc }}-subtle text-{{ rc }}" style="font-size:.7rem;">{{ u.role|upper }}</span>
                </li>
                {% endfor %}
            </ul>
        </div>
    </div>
</div>

{# ── TÂCHES RÉCENTES ── #}
<div class="row g-3 mb-4">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header bg-white px-4 py-3">
                <h4 class="mb-0 h6 fw-bold">📋 Tâches récentes</h4>
            </div>
            <div class="card-body px-0 py-0">
                <ul class="list-group list-group-flush">
                    {% for tache in tachesRecentes %}
                    <li class="list-group-item d-flex justify-content-between align-items-center px-4 py-3">
                        <div>
                            <div class="fw-semibold small">{{ tache.titre }}</div>
                            <div class="text-secondary" style="font-size:.7rem;">
                                {{ employes[tache.employeId] ?? 'Non assigné' }} • 
                                {{ tache.deadline ? tache.deadline|date('d/m/Y') : 'Pas de deadline' }}
                            </div>
                        </div>
                        <span class="badge bg-{{ tache.priorite == 'HAUTE' ? 'danger' : (tache.priorite == 'MOYENNE' ? 'warning' : 'success') }}">
                            {{ tache.priorite }}
                        </span>
                    </li>
                    {% endfor %}
                </ul>
            </div>
            <div class="card-footer bg-white text-center">
                <a href="{{ path('app_tache_index') }}" class="small">Voir toutes les tâches →</a>
            </div>
        </div>
    </div>

    {# ── ACTIONS RAPIDES ── #}
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header bg-white px-4 py-3">
                <h4 class="mb-0 h6 fw-bold">⚡ Actions rapides</h4>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="{{ path('app_tache_new') }}" class="btn btn-outline-primary">
                        <i class="fas fa-plus-circle me-2"></i> Nouvelle tâche
                    </a>
                    <a href="{{ path('app_planning_new') }}" class="btn btn-outline-success">
                        <i class="fas fa-calendar-plus me-2"></i> Nouveau planning
                    </a>
                    <a href="{{ path('app_whiteboard_index') }}" class="btn btn-outline-info">
                        <i class="fas fa-chalkboard me-2"></i> Tableau Kanban
                    </a>
                    <a href="{{ path('app_tache_index') }}" class="btn btn-outline-secondary">
                        <i class="fas fa-list me-2"></i> Toutes les tâches
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// ============ NOTIFICATIONS ============
async function loadNotifications() {
    try {
        const response = await fetch('/api/notifications/me');
        const data = await response.json();
        const container = document.getElementById('notificationsContainer');
        if (data.success && data.data && (data.data.unread_count > 0 || data.data.recent.length > 0)) {
            let html = '<div class="list-group list-group-flush">';
            data.data.unread.forEach(notif => {
                html += `<div class="list-group-item px-4 py-3 bg-light">
                    <div class="d-flex align-items-start gap-3">
                        <div class="flex-shrink-0">${getNotifIcon(notif.type)}</div>
                        <div class="flex-grow-1">
                            <div class="d-flex justify-content-between">
                                <h6 class="mb-0 fw-semibold">${notif.title}</h6>
                                <small class="text-muted">${notif.createdAt}</small>
                            </div>
                            <p class="mb-1 small">${notif.message}</p>
                            <button onclick="markAsRead(${notif.id})" class="btn btn-sm btn-link p-0 small">Marquer comme lu</button>
                        </div>
                        <span class="badge bg-danger rounded-pill">Nouveau</span>
                    </div>
                </div>`;
            });
            data.data.recent.forEach(notif => {
                if (!notif.isRead) return;
                html += `<div class="list-group-item px-4 py-3">
                    <div class="d-flex align-items-start gap-3">
                        <div class="flex-shrink-0">${getNotifIcon(notif.type)}</div>
                        <div class="flex-grow-1">
                            <div class="d-flex justify-content-between">
                                <h6 class="mb-0 fw-semibold">${notif.title}</h6>
                                <small class="text-muted">${notif.createdAt}</small>
                            </div>
                            <p class="mb-1 small text-secondary">${notif.message}</p>
                        </div>
                    </div>
                </div>`;
            });
            html += '</div>';
            container.innerHTML = html;
        } else {
            container.innerHTML = `<div class="text-center text-secondary py-4">
                <i class="fas fa-bell-slash fa-2x mb-2 opacity-50"></i>
                <p>Aucune notification</p>
                <button onclick="sendTestNotification()" class="btn btn-sm btn-primary">Envoyer une notification test</button>
            </div>`;
        }
    } catch (error) {
        document.getElementById('notificationsContainer').innerHTML = `<div class="text-center text-danger py-4"><i class="fas fa-exclamation-circle"></i> Erreur de chargement</div>`;
    }
}

function getNotifIcon(type) {
    switch(type) {
        case 'success': return '<i class="fas fa-check-circle text-success fs-4"></i>';
        case 'danger':  return '<i class="fas fa-exclamation-circle text-danger fs-4"></i>';
        case 'warning': return '<i class="fas fa-exclamation-triangle text-warning fs-4"></i>';
        default:        return '<i class="fas fa-info-circle text-info fs-4"></i>';
    }
}

async function markAsRead(id) {
    await fetch(`/api/notifications/${id}/read`, { method: 'PATCH' });
    loadNotifications();
}

async function sendTestNotification() {
    const btn = event.target.closest('button');
    const orig = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
    btn.disabled = true;
    try {
        await fetch('/api/notifications/check-deadlines', { method: 'POST' });
        showToast('✅ Notification envoyée !', 'success');
        setTimeout(() => loadNotifications(), 1000);
    } finally {
        btn.innerHTML = orig;
        btn.disabled = false;
    }
}

// ============ BADGES ============
async function loadBadges() {
    const container = document.getElementById('badgesContainer');
    try {
        const response = await fetch('/api/badges/me');
        const data = await response.json();

        if (!data.success) {
            container.innerHTML = `<div class="text-center text-danger py-3"><i class="fas fa-exclamation-circle"></i> Erreur chargement badges</div>`;
            return;
        }

        if (data.badges.length === 0) {
            const reste = data.stats.prochain_badge ? data.stats.prochain_badge.reste : '?';
            const nom   = data.stats.prochain_badge ? data.stats.prochain_badge.nom : '';
            const seuil = data.stats.prochain_badge ? data.stats.prochain_badge.seuil : 1;
            const pct   = Math.min(100, Math.round(data.stats.taches_terminees / seuil * 100));
            container.innerHTML = `
                <div class="text-center py-3">
                    <i class="fas fa-trophy fa-3x text-secondary opacity-50 mb-2"></i>
                    <p class="text-secondary mb-1">Aucun badge obtenu pour le moment</p>
                    <small class="text-warning">🎯 Prochain : <strong>${nom}</strong> (encore ${reste} tâches)</small>
                    <div class="progress mt-2 mx-auto" style="height:6px;max-width:300px;">
                        <div class="progress-bar bg-warning" style="width:${pct}%"></div>
                    </div>
                </div>`;
            return;
        }

        let html = '<div class="row g-3">';
        data.badges.forEach(b => {
            html += `
                <div class="col-md-3 col-sm-6">
                    <div class="card text-center border-0 shadow-sm h-100">
                        <div class="card-body py-3">
                            <div style="font-size:2.5rem;">${b.icone}</div>
                            <h6 class="mt-2 mb-1 fw-bold small">${b.nom}</h6>
                            <small class="text-muted d-block">${b.description}</small>
                            <span class="badge bg-success mt-2">✅ ${b.obtenu_le}</span>
                        </div>
                    </div>
                </div>`;
        });
        html += '</div>';

        if (data.stats.prochain_badge) {
            const pct = Math.min(100, Math.round(data.stats.taches_terminees / data.stats.prochain_badge.seuil * 100));
            html += `
                <div class="alert alert-info mt-3 mb-0">
                    <div class="row text-center">
                        <div class="col-6">
                            <div class="fw-bold">${data.stats.taches_terminees}</div>
                            <small>Tâches terminées</small>
                        </div>
                        <div class="col-6">
                            <div class="fw-bold">${data.stats.badges_obtenus}</div>
                            <small>Badges obtenus</small>
                        </div>
                    </div>
                    <div class="mt-2 text-center">
                        <small>🎯 Prochain : <strong>${data.stats.prochain_badge.nom}</strong> (encore ${data.stats.prochain_badge.reste} tâches)</small>
                        <div class="progress mt-1" style="height:5px;">
                            <div class="progress-bar bg-warning" style="width:${pct}%"></div>
                        </div>
                    </div>
                </div>`;
        } else {
            html += `<div class="alert alert-success mt-3 mb-0 text-center">🎉 Félicitations ! Vous avez tous les badges !</div>`;
        }

        container.innerHTML = html;
    } catch (e) {
        container.innerHTML = `<div class="text-center text-danger py-3"><i class="fas fa-exclamation-circle"></i> Erreur de chargement</div>`;
    }
}

async function checkBadges() {
    const btn = event.target.closest('button');
    const orig = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
    btn.disabled = true;
    try {
        const response = await fetch('/api/badges/check', { method: 'POST' });
        const data = await response.json();
        if (data.success && data.new_badges.length > 0) {
            showToast('🏆 ' + data.new_badges.map(b => b.nom).join(', ') + ' débloqué(s) !', 'success');
        } else {
            showToast('Aucun nouveau badge. Continuez !', 'info');
        }
        loadBadges();
    } finally {
        btn.innerHTML = orig;
        btn.disabled = false;
    }
}

function showToast(message, type) {
    const toast = document.createElement('div');
    toast.className = `alert alert-${type} position-fixed top-0 end-0 m-3`;
    toast.style.cssText = 'z-index:9999;animation:slideIn 0.3s ease;min-width:250px;';
    toast.innerHTML = message;
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 3500);
}

document.addEventListener('DOMContentLoaded', function() {
    loadNotifications();
    loadBadges();
    setInterval(loadNotifications, 30000);
});

const style = document.createElement('style');
style.textContent = `
    @keyframes slideIn { from { transform: translateX(100%); opacity:0; } to { transform: translateX(0); opacity:1; } }
    .list-group-item { transition: background-color 0.2s; }
    .list-group-item:hover { background-color: #f8f9fa; }
`;
document.head.appendChild(style);
</script>
{% endblock %}