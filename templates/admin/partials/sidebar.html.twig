<aside id="sidebar" class="sidebar">
    <div class="logo-area">
        <a href="{{ path('admin_dashboard') }}" class="d-inline-flex align-items-center text-decoration-none">
            <img src="/images/logo.png" alt="Stratix" style="height:110px;width:auto;max-width:200px;">
        </a>
    </div>

    <ul class="nav flex-column">

        {# ── ADMIN ONLY ── #}
        {% if app.user and app.user.role == 'admin' %}
        <li class="px-4 py-2"><small class="nav-text text-uppercase" style="font-size:.7rem;letter-spacing:.8px;color:#9ca3af;">Administration</small></li>
        <li>
            <a class="nav-link {% if app.request.attributes.get('_route') == 'admin_dashboard' %}active{% endif %}"
               href="{{ path('admin_dashboard') }}">
                <i class="ti ti-home"></i><span class="nav-text">Dashboard</span>
            </a>
        </li>
        <li>
            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'admin_user' %}active{% endif %}"
               href="{{ path('admin_users') }}">
                <i class="ti ti-users"></i><span class="nav-text">Utilisateurs</span>
            </a>
        </li>
        <li>
            <a class="nav-link {% if app.request.attributes.get('_route') == 'admin_organigramme' %}active{% endif %}"
               href="{{ path('admin_organigramme') }}">
                <i class="ti ti-hierarchy"></i><span class="nav-text">Organigramme</span>
            </a>
        </li>
        {% endif %}

        {# ── RESPONSABLE + ADMIN ── #}

        {% if app.user and app.user.role in ['admin', 'responsable_rh', 'responsable_projet', 'responsable_production', 'ceo'] %}
        <li class="px-4 pt-3 pb-2"><small class="nav-text text-uppercase" style="font-size:.7rem;letter-spacing:.8px;color:#9ca3af;">Gestion</small></li>

        <li>
        <a class="nav-link active" href="{{ path('app_dashboard') }}"><i class="ti ti-home"></i><span class="nav-text">Dashboard</span></a></li>

    
        <li>
            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_tache' %}active{% endif %}"
               href="{{ path('app_tache_index') }}">
                <i class="ti ti-checklist"></i><span class="nav-text">Tâches</span>
            </a>
        </li>
        <li>
            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_tache' %}active{% endif %}"
               href="{{ path('app_planning_index') }}">
                <i class="ti ti-checklist"></i><span class="nav-text">Planning</span>
            </a>
        </li>
        <li>
            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_projet' %}active{% endif %}"
               href="{{ path('app_projet_index') }}">
                <i class="ti ti-folder"></i><span class="nav-text">Projets</span>
            </a>
        </li>
        <li>
            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'resp_event' %}active{% endif %}"
               href="{{ path('resp_event_index') }}">
                <i class="ti ti-calendar-event"></i><span class="nav-text">Événements</span>
            </a>
        </li>
        <li>
            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_whiteboard' %}active{% endif %}"
               href="{{ path('app_whiteboard_index') }}">
                <i class="ti ti-layout-kanban"></i><span class="nav-text">Kanban</span>
            </a>
        </li>
        <li>
            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_calendar' %}active{% endif %}"
               href="{{ path('app_calendar_index') }}">
                <i class="ti ti-calendar-week"></i><span class="nav-text">Calendrier</span>
            </a>
        </li>

        <li class="px-4 pt-3 pb-2"><small class="nav-text text-uppercase" style="font-size:.7rem;letter-spacing:.8px;color:#9ca3af;">Catalogue</small></li>

        <li>
            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_service' %}active{% endif %}"
               href="{{ path('app_service_index') }}">
                <i class="ti ti-building"></i><span class="nav-text">Services</span>
            </a>
        </li>
        <li>
            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_categorie_service' %}active{% endif %}"
               href="{{ path('app_categorie_service_index') }}">
                <i class="ti ti-category"></i><span class="nav-text">Catégories</span>
            </a>
        </li>
        <li>
            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'produit' %}active{% endif %}"
               href="{{ path('produit_index') }}">
                <i class="ti ti-shopping-bag"></i><span class="nav-text">Produits</span>
            </a>
        </li>
        <li>
            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'ressource' %}active{% endif %}"
               href="{{ path('ressource_index') }}">
                <i class="ti ti-package"></i><span class="nav-text">Ressources</span>
            </a>
        </li>
        {% endif %}

        <li class="px-4 pt-3 pb-2"><small class="nav-text text-uppercase" style="font-size:.7rem;letter-spacing:.8px;color:#9ca3af;">Compte</small></li>


        <li>
            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'admin_profile' %}active{% endif %}"
               href="{{ path('admin_profile') }}">
                <i class="ti ti-user-circle"></i><span class="nav-text">Mon profil</span>
            </a>
        </li>
        <li>
            <a class="nav-link text-danger" href="{{ path('app_logout') }}">
                <i class="ti ti-logout"></i><span class="nav-text">Déconnexion</span>
            </a>
        </li>
    </ul>
</aside>