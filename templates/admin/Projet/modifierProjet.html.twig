{# templates/admin/Projet/modifierProjet.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}STRATIX - Modifier {{ projet.nom }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet">
    <style>
        :root {
            --stratix-orange: #f1b31a;
            --stratix-brown:  #5d4037;
            --stratix-input:  #f4f0e8;
        }

        .edit-card { border-radius: 24px; background-color: #fdf6e3; border: none; }

        .form-label-custom {
            font-size: 0.72rem;
            font-weight: 800;
            color: var(--stratix-brown);
            text-transform: uppercase;
            letter-spacing: 0.06em;
            margin-bottom: 0.4rem;
        }

        .input-custom {
            background-color: var(--stratix-input) !important;
            border: 1.5px solid transparent !important;
            border-radius: 12px !important;
            padding: 0.8rem 1rem !important;
            transition: all 0.2s ease;
        }

        .input-custom:focus {
            border-color: var(--stratix-orange) !important;
            box-shadow: 0 0 0 3px rgba(241, 179, 26, 0.18) !important;
            background-color: #fff !important;
        }

        .is-invalid-custom { border-color: #ef4444 !important; background-color: #fff5f5 !important; }

        .field-error {
            color: #ef4444;
            font-size: 0.78rem;
            margin-top: 0.3rem;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .ts-control { border: none !important; background-color: var(--stratix-input) !important; border-radius: 12px !important; }

        .upload-zone {
            border: 2px dashed #d4b483 !important;
            border-radius: 12px !important;
            padding: 1.5rem !important;
            background-color: var(--stratix-input) !important;
            cursor: pointer;
            position: relative;
        }

        .upload-zone:hover { border-color: var(--stratix-orange) !important; background-color: #fff8e1 !important; }

        .current-file-box {
            background: #fff8e1;
            border: 1.5px solid #fde68a;
            border-radius: 10px;
            padding: 0.6rem 1rem;
            font-size: 0.82rem;
            color: #92400e;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .btn-update {
            background: linear-gradient(135deg, var(--stratix-orange), #d9a016);
            color: white;
            border-radius: 15px;
            padding: 1rem;
            font-weight: 700;
            border: none;
            transition: all 0.3s ease;
        }

        .btn-update:hover { transform: translateY(-2px); color: white; opacity: 0.9; }
    </style>
{% endblock %}

{% block body %}
<main class="content py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10 col-xl-8">

                {# Flash messages #}
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success rounded-3 mb-4 border-0 shadow-sm">
                        <i class="fas fa-check-circle me-2"></i> {{ message }}
                    </div>
                {% endfor %}

                <div class="card edit-card shadow-lg p-2 p-md-4">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between mb-5 pb-3 border-bottom border-2" style="border-color: var(--stratix-orange) !important;">
                            <div class="d-flex align-items-center">
                                <div class="bg-warning-subtle p-3 rounded-circle me-3">
                                    <i class="fas fa-pen-nib fa-lg text-warning"></i>
                                </div>
                                <div>
                                    <h3 class="fw-bold mb-0" style="color: var(--stratix-brown);">Modifier le projet</h3>
                                    <p class="text-muted small mb-0">ID: #{{ projet.id }} — Stratix Platform</p>
                                </div>
                            </div>
                            <span class="badge bg-dark rounded-pill px-3 py-2">{{ projet.statut }}</span>
                        </div>

                        {# Erreur globale corrigée #}
                        {% if not form.vars.valid %}
                            <div class="alert alert-danger d-flex align-items-center gap-2 mb-4 border-0 rounded-3">
                                <i class="fas fa-exclamation-triangle"></i>
                                <strong>Veuillez corriger les erreurs ci-dessous.</strong>
                            </div>
                        {% endif %}

                        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                        <div class="row g-4">
                            {# Nom #}
                            <div class="col-12">
                                <label class="form-label-custom">Nom du projet <span class="text-danger">*</span></label>
                                {{ form_widget(form.nom, {'attr': {'class': 'form-control input-custom' ~ (form.nom.vars.errors|length > 0 ? ' is-invalid-custom' : '')}}) }}
                                {% for error in form.nom.vars.errors %}
                                    <div class="field-error"><i class="fas fa-circle-exclamation"></i> {{ error.message }}</div>
                                {% endfor %}
                            </div>

                            {# Budget + Statut #}
                            <div class="col-md-6">
                                <label class="form-label-custom">Budget estimé (DT) <span class="text-danger">*</span></label>
                                {{ form_widget(form.budget, {'attr': {'class': 'form-control input-custom' ~ (form.budget.vars.errors|length > 0 ? ' is-invalid-custom' : '')}}) }}
                                {% for error in form.budget.vars.errors %}
                                    <div class="field-error"><i class="fas fa-circle-exclamation"></i> {{ error.message }}</div>
                                {% endfor %}
                            </div>

                            <div class="col-md-6">
                                <label class="form-label-custom">Statut</label>
                                {{ form_widget(form.statut, {'attr': {'class': 'form-select input-custom fw-bold'}}) }}
                            </div>

                            {# Dates #}
                            <div class="col-md-6">
                                <label class="form-label-custom">Date de début <span class="text-danger">*</span></label>
                                {{ form_widget(form.dateDebut, {'attr': {'class': 'form-control input-custom' ~ (form.dateDebut.vars.errors|length > 0 ? ' is-invalid-custom' : '')}}) }}
                                {% for error in form.dateDebut.vars.errors %}
                                    <div class="field-error"><i class="fas fa-circle-exclamation"></i> {{ error.message }}</div>
                                {% endfor %}
                            </div>

                            <div class="col-md-6">
                                <label class="form-label-custom">Date de fin <span class="text-danger">*</span></label>
                                {{ form_widget(form.dateFin, {'attr': {'class': 'form-control input-custom' ~ (form.dateFin.vars.errors|length > 0 ? ' is-invalid-custom' : '')}}) }}
                                {% for error in form.dateFin.vars.errors %}
                                    <div class="field-error"><i class="fas fa-circle-exclamation"></i> {{ error.message }}</div>
                                {% endfor %}
                            </div>

                            {# Responsable + Membres #}
                            <div class="col-md-6">
                                <label class="form-label-custom">Responsable <span class="text-danger">*</span></label>
                                {{ form_widget(form.responsable, {'attr': {'class': 'form-select input-custom'}}) }}
                            </div>

                            <div class="col-md-6">
                                <label class="form-label-custom">Équipe (Membres)</label>
                                {{ form_widget(form.membres, {'attr': {'class': 'tom-select-edit'}}) }}
                            </div>

                            {# Description #}
                            <div class="col-12">
                                <label class="form-label-custom">Description <span class="text-danger">*</span></label>
                                {{ form_widget(form.description, {'attr': {'class': 'form-control input-custom', 'rows': '4'}}) }}
                            </div>

                            {# Cahier des charges #}
                            <div class="col-12">
                                <label class="form-label-custom"><i class="fas fa-paperclip me-1"></i> Cahier des charges</label>
                                
                                {% if projet.cahierDesCharges %}
                                    <div class="current-file-box mb-2">
                                        <i class="fas fa-file-pdf"></i>
                                        <span>Fichier actuel : {{ projet.cahierDesCharges }}</span>
                                        <a href="{{ asset('uploads/cahiers/' ~ projet.cahierDesCharges) }}" target="_blank" class="text-warning fw-bold ms-auto">Voir</a>
                                    </div>
                                {% endif %}

                                <div class="upload-zone" id="uploadZone">
                                    <div class="text-center">
                                        <i class="fas fa-cloud-upload-alt fa-2x text-warning mb-2"></i>
                                        <div class="fw-semibold small">Cliquez ou glissez le nouveau fichier ici</div>
                                    </div>
                                    {{ form_widget(form.cahierDesChargesFile, {
                                        'attr': {
                                            'class': 'd-none',
                                            'id': 'cahierFile'
                                        }
                                    }) }}
                                </div>
                                <div id="file-preview" style="display:none;" class="mt-2">
                                    <span class="badge bg-warning text-dark p-2 rounded-pill">
                                        <i class="fas fa-file me-1"></i> <span id="file-name-display"></span>
                                    </span>
                                </div>
                                {% for error in form.cahierDesChargesFile.vars.errors %}
                                    <div class="field-error"><i class="fas fa-circle-exclamation"></i> {{ error.message }}</div>
                                {% endfor %}
                            </div>

                            {# Boutons #}
                            <div class="col-12 mt-4">
                                <div class="row g-3">
                                    <div class="col-md-8">
                                        <button type="submit" class="btn btn-update w-100 shadow-sm">
                                            <i class="fas fa-save me-2"></i>ENREGISTRER LES MODIFICATIONS
                                        </button>
                                    </div>
                                    <div class="col-md-4">
                                        <a href="{{ path('app_projet_index') }}" class="btn btn-outline-dark w-100 p-3 fw-bold" style="border-radius:15px;">ANNULER</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/js/tom-select.complete.min.js"></script>
    <script>
    document.addEventListener("DOMContentLoaded", function () {
        // TomSelect
        new TomSelect(".tom-select-edit", { plugins: ['remove_button'] });

        // Upload Zone
        const uploadZone  = document.getElementById('uploadZone');
        // On récupère l'ID généré par Symfony ou forcé
        const cahierInput = document.querySelector('input[type="file"]');
        const filePreview = document.getElementById('file-preview');
        const fileNameEl  = document.getElementById('file-name-display');

        uploadZone.addEventListener('click', () => cahierInput.click());

        cahierInput.addEventListener('change', function () {
            if (this.files && this.files[0]) {
                fileNameEl.textContent = this.files[0].name;
                filePreview.style.display = 'block';
            }
        });

        // Drag and drop
        uploadZone.addEventListener('dragover', (e) => { e.preventDefault(); uploadZone.style.borderColor = "#f1b31a"; });
        uploadZone.addEventListener('dragleave', () => { uploadZone.style.borderColor = "#d4b483"; });
        uploadZone.addEventListener('drop', (e) => {
            e.preventDefault();
            if (e.dataTransfer.files.length) {
                cahierInput.files = e.dataTransfer.files;
                fileNameEl.textContent = e.dataTransfer.files[0].name;
                filePreview.style.display = 'block';
            }
        });
    });
    </script>
{% endblock %}