{% extends 'admin/base_admin.html.twig' %}

{% block title %}Whiteboard - Tableau Kanban{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* Orange Theme Variables */
    :root {
        --orange-primary: #F97316;
        --orange-dark: #EA580C;
        --orange-light: #FFEDD5;
        --orange-bg: #FFF7ED;
        --gray-bg: #F8FAFE;
        --gray-border: #E2E8F0;
        --text-dark: #1E293B;
        --text-gray: #64748B;
    }

    .container-fluid {
        background: linear-gradient(135deg, #FFF9F0 0%, #FFFFFF 50%, #FFF5E6 100%);
        min-height: 100vh;
        padding: 1.5rem;
    }

    /* Header Section */
    .page-header {
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid var(--orange-light);
    }

    .page-header h1 {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--text-dark);
        letter-spacing: -0.02em;
    }

    .page-header h1 i {
        color: var(--orange-primary);
        margin-right: 12px;
        background: var(--orange-light);
        padding: 10px;
        border-radius: 14px;
    }

    /* Kanban Board */
    .kanban-board {
        display: flex;
        gap: 24px;
        padding: 10px 0;
        align-items: flex-start;
        overflow-x: auto;
        padding-bottom: 20px;
    }

    .kanban-column {
        background: white;
        border-radius: 20px;
        padding: 16px;
        width: 340px;
        min-width: 340px;
        min-height: 550px;
        flex-shrink: 0;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        border: 1px solid var(--gray-border);
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .kanban-column:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 30px rgba(249, 115, 22, 0.12);
        border-color: var(--orange-light);
    }

    .column-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-bottom: 14px;
        margin-bottom: 16px;
        border-bottom: 2px solid var(--orange-light);
        font-weight: 700;
        font-size: 16px;
        color: var(--text-dark);
    }

    .column-header span:first-child {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .count-badge {
        background: linear-gradient(135deg, var(--orange-primary), var(--orange-dark));
        color: white;
        border-radius: 30px;
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 700;
        box-shadow: 0 2px 8px rgba(249, 115, 22, 0.3);
    }

    .tasks-container {
        min-height: 80px;
        transition: background 0.2s;
        border-radius: 12px;
        padding: 6px;
    }

    .tasks-container.drag-over {
        background-color: var(--orange-light);
        border: 2px dashed var(--orange-primary);
    }

    /* Task Card */
    .task-card {
        background: white;
        border-radius: 14px;
        padding: 14px;
        margin-bottom: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
        cursor: grab;
        border-left: 5px solid;
        transition: all 0.25s ease;
        position: relative;
    }

    .task-card:active { 
        cursor: grabbing; 
    }

    .task-card.dragging {
        opacity: 0.4;
        transform: rotate(2deg) scale(0.98);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
    }

    .task-card:hover {
        transform: translateX(4px);
        box-shadow: 0 8px 20px rgba(249, 115, 22, 0.15);
        border-left-width: 6px;
    }

    .task-priorite-haute   { border-left-color: #EF4444; }
    .task-priorite-moyenne { border-left-color: #F59E0B; }
    .task-priorite-basse   { border-left-color: #10B981; }

    .task-title {
        font-weight: 700;
        font-size: 15px;
        margin-bottom: 8px;
        color: var(--text-dark);
    }

    .task-description {
        font-size: 12px;
        color: var(--text-gray);
        margin-bottom: 10px;
        line-height: 1.4;
    }

    .task-meta {
        font-size: 11px;
        color: #94A3B8;
        display: flex;
        justify-content: space-between;
        margin-top: 8px;
        padding-top: 8px;
        border-top: 1px solid #F1F5F9;
    }

    .task-meta i {
        margin-right: 4px;
        color: var(--orange-primary);
    }

    .badge-priorite {
        padding: 4px 10px;
        border-radius: 30px;
        font-size: 10px;
        font-weight: 700;
        display: inline-block;
        margin-top: 8px;
    }

    .badge-haute   { background-color: #FEE2E2; color: #DC2626; }
    .badge-moyenne { background-color: #FEF3C7; color: #D97706; }
    .badge-basse   { background-color: #D1FAE5; color: #059669; }

    /* Boutons d'action */
    .task-actions {
        display: flex;
        gap: 6px;
        margin-top: 12px;
        flex-wrap: wrap;
    }

    .task-actions .btn-sm {
        padding: 4px 10px;
        font-size: 11px;
        border-radius: 20px;
        font-weight: 600;
        transition: all 0.2s;
    }

    .task-actions .btn-warning {
        background: linear-gradient(135deg, #FEF3C7, #FDE68A);
        border: none;
        color: #B45309;
    }

    .task-actions .btn-warning:hover {
        background: linear-gradient(135deg, #FDE68A, #FCD34D);
        transform: translateY(-1px);
    }

    .task-actions .btn-info {
        background: linear-gradient(135deg, var(--orange-light), #FED7AA);
        border: none;
        color: var(--orange-dark);
    }

    .task-actions .btn-info:hover {
        background: linear-gradient(135deg, #FED7AA, #FDC68A);
        transform: translateY(-1px);
    }

    .task-actions .btn-success {
        background: linear-gradient(135deg, #D1FAE5, #A7F3D0);
        border: none;
        color: #047857;
    }

    .task-actions .btn-success:hover {
        background: linear-gradient(135deg, #A7F3D0, #6EE7B7);
        transform: translateY(-1px);
    }

    .task-actions .btn-secondary {
        background: #F1F5F9;
        border: none;
        color: #475569;
    }

    .task-actions .btn-secondary:hover {
        background: #E2E8F0;
        transform: translateY(-1px);
    }

    .task-actions .btn-danger {
        background: linear-gradient(135deg, #FEE2E2, #FECACA);
        border: none;
        color: #DC2626;
    }

    .task-actions .btn-danger:hover {
        background: linear-gradient(135deg, #FECACA, #FCA5A5);
        transform: translateY(-1px);
    }

    /* Empty state */
    .empty-state {
        text-align: center;
        padding: 40px 20px;
        color: var(--text-gray);
    }

    .empty-state i {
        font-size: 2.5rem;
        margin-bottom: 12px;
        opacity: 0.5;
        color: var(--orange-primary);
    }

    .empty-state p {
        font-size: 13px;
        margin: 0;
    }

    /* Drop placeholder */
    .drop-placeholder {
        background: linear-gradient(135deg, var(--orange-light), #FFF7ED);
        border: 2px dashed var(--orange-primary);
        border-radius: 14px;
        height: 90px;
        margin-bottom: 12px;
    }

    /* Toast notifications */
    .toast-container {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 9999;
    }

    .toast-custom {
        background: white;
        border-radius: 16px;
        padding: 12px 20px;
        margin-bottom: 10px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.12);
        font-weight: 600;
        font-size: 13px;
        display: flex;
        align-items: center;
        gap: 10px;
        animation: slideInRight 0.3s ease;
        border-left: 4px solid var(--orange-primary);
    }

    .toast-custom.success {
        border-left-color: #10B981;
    }

    .toast-custom.danger {
        border-left-color: #EF4444;
    }

    @keyframes slideInRight {
        from {
            transform: translateX(100%);
            opacity: 0;
        }
        to {
            transform: translateX(0);
            opacity: 1;
        }
    }

    @keyframes fadeOut {
        to {
            opacity: 0;
            transform: translateX(100%);
        }
    }

    /* Scrollbar styling */
    .kanban-board::-webkit-scrollbar {
        height: 8px;
    }

    .kanban-board::-webkit-scrollbar-track {
        background: var(--orange-light);
        border-radius: 10px;
    }

    .kanban-board::-webkit-scrollbar-thumb {
        background: var(--orange-primary);
        border-radius: 10px;
    }

    .kanban-board::-webkit-scrollbar-thumb:hover {
        background: var(--orange-dark);
    }
</style>
{% endblock %}

{% block admin_content %}
<div class="container-fluid">
    <div class="page-header">
        <h1><i class="fas fa-chalkboard"></i> Tableau Kanban</h1>
    </div>

    <div class="toast-container" id="toastContainer"></div>

    <div class="kanban-board">

        {# ===== COLONNE À FAIRE ===== #}
        <div class="kanban-column">
            <div class="column-header">
                <span><i class="fas fa-clipboard-list" style="color: var(--orange-primary);"></i> À FAIRE</span>
                <span class="count-badge" id="count-A_FAIRE">{{ countAFaire }}</span>
            </div>
            <div class="tasks-container" data-statut="A_FAIRE" id="col-A_FAIRE">
                {% for tache in tachesAFaire %}
                <div class="task-card task-priorite-{{ tache.priorite|lower }}"
                     draggable="true"
                     data-id="{{ tache.id }}"
                     data-statut="A_FAIRE">
                    <div class="task-title">{{ tache.titre }}</div>
                    <div class="task-description">{{ tache.description|slice(0,80) }}{% if tache.description|length > 80 %}...{% endif %}</div>
                    <div class="task-meta">
                        <span><i class="fas fa-user"></i> {{ tache.employeNom }}</span>
                        <span><i class="fas fa-calendar-alt"></i> {{ tache.deadline }}</span>
                    </div>
                    <span class="badge-priorite badge-{{ tache.priorite|lower }}">
                        {% if tache.priorite == 'HAUTE' %}🔴 Haute
                        {% elseif tache.priorite == 'MOYENNE' %}🟡 Moyenne
                        {% else %}🟢 Basse{% endif %}
                    </span>
                    <div class="task-actions">
                        <a href="{{ path('app_tache_edit', {'id': tache.id}) }}" class="btn btn-sm btn-warning">
                            <i class="fas fa-edit"></i> Modifier
                        </a>
                        <form method="post" action="{{ path('app_whiteboard_move', {'id': tache.id, 'newStatut': 'EN_COURS'}) }}" style="display:inline">
                            <button type="submit" class="btn btn-sm btn-info">
                                <i class="fas fa-arrow-right"></i> Démarrer
                            </button>
                        </form>
                        <form method="post" action="{{ path('app_whiteboard_delete', {'id': tache.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer cette tâche ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tache.id) }}">
                            <button class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                        </form>
                    </div>
                </div>
                {% else %}
                <div class="empty-state">
                    <i class="fas fa-inbox"></i>
                    <p>Aucune tâche à faire</p>
                </div>
                {% endfor %}
            </div>
        </div>

        {# ===== COLONNE EN COURS ===== #}
        <div class="kanban-column">
            <div class="column-header">
                <span><i class="fas fa-bolt" style="color: var(--orange-primary);"></i> EN COURS</span>
                <span class="count-badge" id="count-EN_COURS">{{ countEnCours }}</span>
            </div>
            <div class="tasks-container" data-statut="EN_COURS" id="col-EN_COURS">
                {% for tache in tachesEnCours %}
                <div class="task-card task-priorite-{{ tache.priorite|lower }}"
                     draggable="true"
                     data-id="{{ tache.id }}"
                     data-statut="EN_COURS">
                    <div class="task-title">{{ tache.titre }}</div>
                    <div class="task-description">{{ tache.description|slice(0,80) }}{% if tache.description|length > 80 %}...{% endif %}</div>
                    <div class="task-meta">
                        <span><i class="fas fa-user"></i> {{ tache.employeNom }}</span>
                        <span><i class="fas fa-calendar-alt"></i> {{ tache.deadline }}</span>
                    </div>
                    <span class="badge-priorite badge-{{ tache.priorite|lower }}">
                        {% if tache.priorite == 'HAUTE' %}🔴 Haute
                        {% elseif tache.priorite == 'MOYENNE' %}🟡 Moyenne
                        {% else %}🟢 Basse{% endif %}
                    </span>
                    <div class="task-actions">
                        <a href="{{ path('app_tache_edit', {'id': tache.id}) }}" class="btn btn-sm btn-warning">
                            <i class="fas fa-edit"></i> Modifier
                        </a>
                        <form method="post" action="{{ path('app_whiteboard_move', {'id': tache.id, 'newStatut': 'TERMINEE'}) }}" style="display:inline">
                            <button type="submit" class="btn btn-sm btn-success">
                                <i class="fas fa-check"></i> Terminer
                            </button>
                        </form>
                        <form method="post" action="{{ path('app_whiteboard_move', {'id': tache.id, 'newStatut': 'A_FAIRE'}) }}" style="display:inline">
                            <button type="submit" class="btn btn-sm btn-secondary">
                                <i class="fas fa-arrow-left"></i> Reculer
                            </button>
                        </form>
                        <form method="post" action="{{ path('app_whiteboard_delete', {'id': tache.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer cette tâche ?')">
                            <button class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                        </form>
                    </div>
                </div>
                {% else %}
                <div class="empty-state">
                    <i class="fas fa-inbox"></i>
                    <p>Aucune tâche en cours</p>
                </div>
                {% endfor %}
            </div>
        </div>

        {# ===== COLONNE TERMINÉE ===== #}
        <div class="kanban-column">
            <div class="column-header">
                <span><i class="fas fa-check-circle" style="color: var(--orange-primary);"></i> TERMINÉE</span>
                <span class="count-badge" id="count-TERMINEE">{{ countTerminees }}</span>
            </div>
            <div class="tasks-container" data-statut="TERMINEE" id="col-TERMINEE">
                {% for tache in tachesTerminees %}
                <div class="task-card task-priorite-{{ tache.priorite|lower }}"
                     draggable="true"
                     data-id="{{ tache.id }}"
                     data-statut="TERMINEE">
                    <div class="task-title">{{ tache.titre }}</div>
                    <div class="task-description">{{ tache.description|slice(0,80) }}{% if tache.description|length > 80 %}...{% endif %}</div>
                    <div class="task-meta">
                        <span><i class="fas fa-user"></i> {{ tache.employeNom }}</span>
                        <span><i class="fas fa-calendar-alt"></i> {{ tache.deadline }}</span>
                    </div>
                    <span class="badge-priorite badge-{{ tache.priorite|lower }}">
                        {% if tache.priorite == 'HAUTE' %}🔴 Haute
                        {% elseif tache.priorite == 'MOYENNE' %}🟡 Moyenne
                        {% else %}🟢 Basse{% endif %}
                    </span>
                    <div class="task-actions">
                        <a href="{{ path('app_tache_edit', {'id': tache.id}) }}" class="btn btn-sm btn-warning">
                            <i class="fas fa-edit"></i> Modifier
                        </a>
                        <form method="post" action="{{ path('app_whiteboard_move', {'id': tache.id, 'newStatut': 'EN_COURS'}) }}" style="display:inline">
                            <button type="submit" class="btn btn-sm btn-secondary">
                                <i class="fas fa-undo"></i> Réactiver
                            </button>
                        </form>
                        <form method="post" action="{{ path('app_whiteboard_delete', {'id': tache.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer cette tâche ?')">
                            <button class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                        </form>
                    </div>
                </div>
                {% else %}
                <div class="empty-state">
                    <i class="fas fa-inbox"></i>
                    <p>Aucune tâche terminée</p>
                </div>
                {% endfor %}
            </div>
        </div>

    </div>
</div>

<script>
const moveUrl = '/whiteboard/move/';
let draggedCard = null;
let placeholder = null;

document.querySelectorAll('.task-card').forEach(card => initCard(card));

function initCard(card) {
    card.addEventListener('dragstart', e => {
        draggedCard = card;
        setTimeout(() => card.classList.add('dragging'), 0);
        e.dataTransfer.effectAllowed = 'move';
    });
    card.addEventListener('dragend', () => {
        card.classList.remove('dragging');
        removePlaceholder();
        draggedCard = null;
    });
}

document.querySelectorAll('.tasks-container').forEach(col => {
    col.addEventListener('dragover', e => {
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
        col.classList.add('drag-over');
        const afterEl = getDragAfterElement(col, e.clientY);
        if (!placeholder) {
            placeholder = document.createElement('div');
            placeholder.className = 'drop-placeholder';
        }
        if (afterEl == null) {
            col.appendChild(placeholder);
        } else {
            col.insertBefore(placeholder, afterEl);
        }
    });

    col.addEventListener('dragleave', e => {
        if (!col.contains(e.relatedTarget)) {
            col.classList.remove('drag-over');
            removePlaceholder();
        }
    });

    col.addEventListener('drop', e => {
        e.preventDefault();
        col.classList.remove('drag-over');
        removePlaceholder();
        if (!draggedCard) return;

        const newStatut = col.dataset.statut;
        const oldStatut = draggedCard.dataset.statut;
        const id = draggedCard.dataset.id;

        const afterEl = getDragAfterElement(col, e.clientY);
        if (afterEl == null) {
            col.appendChild(draggedCard);
        } else {
            col.insertBefore(draggedCard, afterEl);
        }

        draggedCard.dataset.statut = newStatut;
        updateCount(oldStatut);
        updateCount(newStatut);

        if (oldStatut === newStatut) return;

        fetch(moveUrl + id + '/' + newStatut, {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(r => {
            if (r.ok || r.redirected) {
                showToast('✅ Tâche déplacée vers ' + labelStatut(newStatut));
            } else {
                showToast('❌ Erreur serveur', 'danger');
            }
        })
        .catch(() => showToast('❌ Erreur réseau', 'danger'));
    });
});

function getDragAfterElement(container, y) {
    const draggables = [...container.querySelectorAll('.task-card:not(.dragging)')];
    return draggables.reduce((closest, child) => {
        const box = child.getBoundingClientRect();
        const offset = y - box.top - box.height / 2;
        if (offset < 0 && offset > closest.offset) {
            return { offset, element: child };
        }
        return closest;
    }, { offset: Number.NEGATIVE_INFINITY }).element;
}

function removePlaceholder() {
    if (placeholder && placeholder.parentNode) {
        placeholder.parentNode.removeChild(placeholder);
    }
    placeholder = null;
}

function updateCount(statut) {
    const col = document.getElementById('col-' + statut);
    const count = col.querySelectorAll('.task-card').length;
    document.getElementById('count-' + statut).textContent = count;
}

function labelStatut(s) {
    return { 'A_FAIRE': 'À Faire', 'EN_COURS': 'En Cours', 'TERMINEE': 'Terminée' }[s] || s;
}

function showToast(msg, type = 'success') {
    const container = document.getElementById('toastContainer');
    const toast = document.createElement('div');
    toast.className = toast-custom ${type};
    const icon = type === 'success' ? '✅' : '❌';
    toast.innerHTML = ${icon} ${msg};
    container.appendChild(toast);
    setTimeout(() => {
        toast.style.animation = 'fadeOut 0.3s ease';
        setTimeout(() => toast.remove(), 300);
    }, 3000);
}
</script>
{% endblock %}