{% extends 'base.html.twig' %}

{% block title %}Modifier le Sprint - STRATIX{% endblock %}

{% block body %}
<main id="content" class="content py-4">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                
                {# Fil d'Ariane pour la navigation #}
                <nav aria-label="breadcrumb" class="mb-4">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item">
                            <a href="{{ path('app_projet_show', {'id': sprint.projet.id}) }}" class="text-danger text-decoration-none">
                                {{ sprint.projet.nom }}
                            </a>
                        </li>
                        <li class="breadcrumb-item active">Modifier Sprint</li>
                    </ol>
                </nav>

                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="card-header bg-white border-bottom py-3">
                        <h5 class="mb-0 fw-bold text-dark">
                            <i class="fas fa-edit me-2 text-warning"></i>Modifier le Sprint : {{ sprint.nom }}
                        </h5>
                    </div>
                    <div class="card-body p-4">
                        {{ form_start(form) }}
                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted">NOM DU SPRINT</label>
                                {{ form_widget(form.nom) }}
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold small text-muted">DATE DE DÉBUT</label>
                                    {{ form_widget(form.dateDebut) }}
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold small text-muted">DATE DE FIN</label>
                                    {{ form_widget(form.dateFin) }}
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold small text-muted">STATUT ACTUEL</label>
                                {{ form_widget(form.statut) }}
                            </div>

                            <div class="d-flex gap-2">
                                <button class="btn btn-danger rounded-3 fw-bold w-100">
                                    <i class="fas fa-save me-1"></i> Enregistrer les modifications
                                </button>
                                <a href="{{ path('app_projet_show', {'id': sprint.projet.id}) }}" class="btn btn-light border rounded-3 w-100">
                                    Annuler
                                </a>
                            </div>
                        {{ form_end(form) }}
                    </div>
                </div>

                {# Optionnel : Zone de danger (Suppression) #}
                <div class="mt-4 p-3 bg-light rounded-3 border">
                    <p class="small text-muted mb-2">Actions irréversibles</p>
                    <form method="post" action="{{ path('app_sprint_delete', {'id': sprint.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce sprint ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ sprint.id) }}">
                        <button class="btn btn-sm btn-outline-secondary border-0">
                            <i class="fas fa-trash-alt me-1"></i> Supprimer le sprint
                        </button>
                    </form>
                </div>

            </div>
        </div>
    </div>
</main>
{% endblock %}