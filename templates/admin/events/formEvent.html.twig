{% extends 'base.html.twig' %}

{% block title %}{{ evenement.id ? 'Modifier' : 'Nouvel' }} Événement{% endblock %}

{% block body %}
<div id="overlay" class="overlay"></div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>

<style>

    .form-control, .form-select {
        border-color: #e2e8f0;
        font-size: .875rem;
    }
    .form-control:focus, .form-select:focus {
        border-color: #7c3aed;
        box-shadow: 0 0 0 3px rgba(124,58,237,.08);
    }
    .input-group-text {
        border-color: #e2e8f0;
    }
    .form-control.is-invalid {
        border-color: #dc2626 !important;
        background-image: none;
    }
    .invalid-feedback, .form-error-message {
        color: #dc2626 !important;
        font-size: .75rem;
        margin-top: .25rem;
        display: flex;
        align-items: center;
        gap: 4px;
    }
    .invalid-feedback::before, .form-error-message::before {
        content: '\ea0d';
        font-family: 'tabler-icons';
        font-size: .8rem;
    }
    .type-option, .statut-option {
        transition: all .15s ease;
    }
    .type-option:hover, .statut-option:hover {
        background: #faf5ff;
        border-color: #c4b5fd !important;
    }
    .section-label {
        font-size: .68rem;
        font-weight: 600;
        letter-spacing: .06em;
        color: #94a3b8;
        text-transform: uppercase;
        margin-bottom: 1rem;
    }

    .form-error-icon {
        color: #dc2626;
    }
    ul.form-errors, .form-errors {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    ul li, .form-error-message {
        color: #dc2626 !important;
        font-size: .75rem;
        margin-top: .3rem;
        display: flex;
        align-items: center;
        gap: 4px;
    }

</style>

<main id="content" class="content py-10">
    <div class="container-fluid">

        <div class="row mb-4">
            <div class="col-12">
                <a href="{{ path('resp_event_index') }}"
                   class="text-muted small text-decoration-none d-inline-flex align-items-center gap-1 mb-2">
                    <i class="ti ti-arrow-left"></i> Retour aux événements
                </a>
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-2 p-2" style="background:#ede9fe;">
                        <i class="ti ti-{{ evenement.id ? 'pencil' : 'calendar-plus' }} fs-5" style="color:#7c3aed;"></i>
                    </div>
                    <div>
                        <h1 class="fs-4 fw-semibold text-dark mb-0">
                            {{ evenement.id ? 'Modifier l\'événement' : 'Nouvel événement' }}
                        </h1>
                    </div>
                </div>
            </div>
        </div>

        {{ form_start(form, {
            'action': evenement.id ? path('resp_event_edit', {'id': evenement.id}) : path('resp_event_new'),
            'method': 'POST',
            'attr': {
                'novalidate': 'novalidate',
                'enctype': 'multipart/form-data'
            }
        }) 
        }}
        <div class="row g-4">

            <div class="col-lg-8 d-flex flex-column gap-4">

                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <p class="section-label">Informations générales</p>

                        <div class="mb-4">
                            <label class="form-label small fw-semibold text-dark mb-1">
                                Titre <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0 text-muted">
                                    <i class="ti ti-text-size"></i>
                                </span>
                                {{ form_widget(form.titre, {
                                    'attr': {
                                        'class': 'form-control border-start-0 ps-0',
                                        'placeholder': 'runion trimestrielle'
                                    }
                                }) }}
                            </div>
                            {{ form_errors(form.titre) }}
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-semibold text-dark mb-1">
                                Description <span class="text-danger">*</span>
                            </label>
                            {{ form_widget(form.description, {
                                'attr': {
                                    'class': 'form-control',
                                    'rows': 5,
                                    'placeholder': 'description...'
                                }
                            }) }}
                            {{ form_errors(form.description) }}
                        </div>

                        <div class="row g-3">
                            <div class="col-sm-6">
                                <label class="form-label small fw-semibold text-dark mb-1">
                                    Date <span class="text-danger">*</span>
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0 text-muted">
                                        <i class="ti ti-calendar"></i>
                                    </span>
                                    {{ form_widget(form.dateEvent, {
                                        'attr': {'class': 'form-control border-start-0 ps-0'}
                                    }) }}
                                </div>
                                {{ form_errors(form.dateEvent) }}
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Lieu</label>
                                {{ form_widget(form.lieu, {
                                    'attr': {
                                        'class': 'form-control',
                                        'placeholder': 'Entrez une adresse...',
                                        'id': 'lieu-input',
                                        'autocomplete': 'off'
                                    }
                                }) }}
                                {{ form_errors(form.lieu) }}

                                <div id="suggestions" class="list-group mt-1 position-absolute z-3" style="max-width:400px;"></div>
                            </div>

                            {{ form_widget(form.latitude, {'attr': {'id': 'latitude-input'}}) }}
                            {{ form_widget(form.longitude, {'attr': {'id': 'longitude-input'}}) }}

                            <div id="map" class="rounded-2 mt-2" style="height:300px; z-index:1;"></div>
                        </div>

                    </div>
                </div>

                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <p class="section-label">Image</p>
                        <div class="d-flex gap-3 align-items-start">

                            <div id="imgPreview" class="rounded-2 d-flex align-items-center justify-content-center flex-shrink-0 overflow-hidden"
                                style="width:80px; height:80px; background:#f1f5f9; border: 1.5px dashed #cbd5e1;">
                                {% if evenement.imageUrl %}
                                    <img src="{{ asset(evenement.imageUrl) }}"
                                        style="width:80px;height:80px;object-fit:cover;"
                                        onerror="this.parentElement.innerHTML='<i class=\'ti ti-photo text-muted fs-3\'></i>'">
                                {% else %}
                                    <i class="ti ti-photo text-muted fs-3"></i>
                                {% endif %}
                            </div>

                            <div class="flex-grow-1">
                                <label class="form-label small fw-semibold text-dark mb-1">
                                    Choisir une image
                                </label>

                                
                                {{ form_widget(form.image, {
                                    'attr': {
                                        'class': 'form-control form-control-sm',
                                        'id': 'imageUrlInput',
                                        'accept': 'image/jpeg, image/png, image/webp'
                                    }
                                }) }}

                                {{ form_errors(form.image) }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 d-flex flex-column gap-4">

                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <p class="section-label">Type d'événement <span class="text-danger">*</span></p>

                        <div class="d-flex flex-column gap-2">
                            {% set icons = {
                                'formation':        ['ti-school',       '#8b5cf6', '#f5f3ff'],
                                'reunion':          ['ti-users',        '#3b82f6', '#eff6ff'],
                                'lancementProduit': ['ti-rocket',       '#10b981', '#ecfdf5'],
                                'recrutement':      ['ti-user-plus',    '#ef4444', '#fef2f2'],
                                'seminaire':        ['ti-presentation', '#f59e0b', '#fffbeb']
                            } %}
                            {% for choice in form.typeEvent %}
                                {% set val = choice.vars.value %}
                                <label class="d-flex align-items-center gap-3 px-3 py-2 rounded-2 type-option"
                                       style="border: 1.5px solid #e2e8f0; cursor:pointer;">
                                    {{ form_widget(choice, {'attr': {'class': 'd-none type-radio'}}) }}
                                    {% if val in icons|keys %}
                                        {% set ic = icons[val] %}
                                        <div class="rounded-2 p-1 d-flex align-items-center justify-content-center"
                                             style="background:{{ ic[2] }}; min-width:28px; height:28px;">
                                            <i class="ti {{ ic[0] }} small" style="color:{{ ic[1] }};"></i>
                                        </div>
                                    {% endif %}
                                    <span class="small fw-semibold text-dark">{{ choice.vars.label }}</span>
                                </label>
                            {% endfor %}
                        </div>
                        {{ form_errors(form.typeEvent ) }}
                    </div>
                </div>

                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <p class="section-label">Statut <span class="text-danger">*</span></p>

                        <div class="d-flex flex-column gap-2">
                            {% for choice in form.statut %}
                                {% set val = choice.vars.value %}
                                <label class="d-flex align-items-center gap-3 px-3 py-2 rounded-2 statut-option"
                                       style="border: 1.5px solid #e2e8f0; cursor:pointer;">
                                    {{ form_widget(choice, {'attr': {'class': 'd-none statut-radio'}}) }}
                                    {% if val == 'planifier' %}
                                        <div class="rounded-2 p-1 d-flex align-items-center justify-content-center"
                                             style="background:#dcfce7; min-width:28px; height:28px;">
                                            <i class="ti ti-circle-check small" style="color:#16a34a;"></i>
                                        </div>
                                        <span class="small fw-semibold text-dark">Planifié</span>
                                    {% elseif val == 'terminer' %}
                                        <div class="rounded-2 p-1 d-flex align-items-center justify-content-center"
                                             style="background:#fef9c3; min-width:28px; height:28px;">
                                            <i class="ti ti-flag small" style="color:#ca8a04;"></i>
                                        </div>
                                        <span class="small fw-semibold text-dark">Terminé</span>
                                    {% elseif val == 'annuler' %}
                                        <div class="rounded-2 p-1 d-flex align-items-center justify-content-center"
                                             style="background:#fee2e2; min-width:28px; height:28px;">
                                            <i class="ti ti-ban small" style="color:#dc2626;"></i>
                                        </div>
                                        <span class="small fw-semibold text-dark">Annulé</span>
                                    {% endif %}
                                </label>
                            {% endfor %}
                        </div>
                        {{ form_errors(form.statut) }}
                    </div>
                </div>
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <p class="section-label">Récurrence</p>
                        {{ form_widget(form.recurrence, {
                            'attr': {'class': 'form-select'}
                        }) }}
                        {{ form_errors(form.recurrence) }}
                        <small class="text-muted">
                            Si vous choisissez une répétition, 4 occurrences seront créées automatiquement.
                        </small>
                    </div>
                </div>

                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4 d-flex flex-column gap-2">
                        <p class="section-label mb-3">Actions</p>
                        <button type="submit" class="btn btn-primary w-100 py-2 d-flex align-items-center justify-content-center gap-2">
                            <i class="ti ti-{{ evenement.id ? 'device-floppy' : 'calendar-plus' }}"></i>
                            {{ evenement.id ? 'Enregistrer les modifications' : 'Créer l\'événement' }}
                        </button>
                        <a href="{{ path('resp_event_index') }}"
                           class="btn btn-outline-secondary w-100 py-2 d-flex align-items-center justify-content-center gap-2">
                            <i class="ti ti-x"></i> Annuler
                        </a>
                    </div>
                </div>

            </div>
        </div>

        {{ form_end(form) }}

        <footer class="text-center py-3 mt-5 text-muted small">
            Copyright © 2026 InApp Inventory Dashboard.
        </footer>

    </div>
</main>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
    const imgInput = document.getElementById('imageUrlInput');
    const imgPreview = document.getElementById('imgPreview');

    if (imgInput) {
        imgInput.addEventListener('input', function () {
            const val = this.value.trim();
            if (val) {
                imgPreview.innerHTML = `<img src="/images/events/${val}"
                    style="width:80px;height:80px;object-fit:cover;border-radius:8px;"
                    onerror="this.parentElement.innerHTML='<i class=\\'ti ti-photo text-muted fs-3\\'></i>'">`;
            } else {
                imgPreview.innerHTML = '<i class="ti ti-photo text-muted fs-3"></i>';
            }
        });
    }

    document.querySelectorAll('.type-radio').forEach(radio => {
        const apply = () => {
            document.querySelectorAll('.type-option').forEach(l => {
                l.style.borderColor = '#e2e8f0';
                l.style.background = '';
            });
            if (radio.checked) {
                radio.closest('.type-option').style.borderColor = '#7c3aed';
                radio.closest('.type-option').style.background = '#faf5ff';
            }
        };
        radio.addEventListener('change', apply);
        if (radio.checked) apply();
    });

    document.querySelectorAll('.statut-radio').forEach(radio => {
        const apply = () => {
            document.querySelectorAll('.statut-option').forEach(l => {
                l.style.borderColor = '#e2e8f0';
                l.style.background = '';
            });
            if (radio.checked) {
                radio.closest('.statut-option').style.borderColor = '#7c3aed';
                radio.closest('.statut-option').style.background = '#faf5ff';
            }
        };
        radio.addEventListener('change', apply);
        if (radio.checked) apply();
    });




    const lieuInput = document.querySelector('[name="evenement[lieu]"]');
    const latInput  = document.querySelector('[name="evenement[latitude]"]');
    const lngInput  = document.querySelector('[name="evenement[longitude]"]');
    const suggestions = document.getElementById('suggestions');

    console.log('lieu:', lieuInput);
    console.log('lat:', latInput);
    console.log('lng:', lngInput);

    const defaultLat = parseFloat(latInput?.value) || 36.8065;
    const defaultLng = parseFloat(lngInput?.value) || 10.1815;

    const map = L.map('map').setView([defaultLat, defaultLng], 13);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors'
    }).addTo(map);

    let marker = L.marker([defaultLat, defaultLng]).addTo(map);

    //  map → update address field ---
    map.on('click', function(e) {
        const { lat, lng } = e.latlng;

        marker.setLatLng([lat, lng]);
        latInput.value = lat;
        lngInput.value = lng;

        fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lng}&format=json`)
            .then(r => r.json())
            .then(data => {
                console.log('Reverse geocode result:', data);
                lieuInput.value = data.display_name ?? `${lat}, ${lng}`;
            })
            .catch(err => console.error('Reverse geocode error:', err));
    });

    // address → suggestions
    let debounce;
    lieuInput.addEventListener('input', function() {
        clearTimeout(debounce);
        const query = this.value.trim();
        console.log('Searching for:', query);

        if (query.length < 3) {
            suggestions.innerHTML = '';
            return;
        }

        debounce = setTimeout(() => {
            fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(query)}&format=json&limit=5`)
                .then(r => r.json())
                .then(results => {
                    console.log('Search results:', results);
                    suggestions.innerHTML = '';
                    results.forEach(place => {
                        const item = document.createElement('button');
                        item.type = 'button';
                        item.className = 'list-group-item list-group-item-action small';
                        item.textContent = place.display_name;
                        item.addEventListener('click', () => {
                            const lat = parseFloat(place.lat);
                            const lng = parseFloat(place.lon);

                            lieuInput.value = place.display_name;
                            latInput.value  = lat;
                            lngInput.value  = lng;

                            marker.setLatLng([lat, lng]);
                            map.setView([lat, lng], 14);
                            suggestions.innerHTML = '';
                        });
                        suggestions.appendChild(item);
                    });
                })
                .catch(err => console.error('Search error:', err));
        }, 400);
    });

    // Close suggestions when clicking outside
    document.addEventListener('click', function(e) {
        if (!lieuInput.contains(e.target)) {
            suggestions.innerHTML = '';
        }
    });
</script>

{% endblock %}