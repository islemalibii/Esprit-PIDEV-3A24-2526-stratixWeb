<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: Arial, sans-serif; padding: 30px; color: #333; }
        h1   { color: #7c3aed; border-bottom: 2px solid #7c3aed; padding-bottom: 10px; }
        .badge { padding: 4px 10px; border-radius: 20px; font-size: 12px; }
        .detail-row { display: flex; gap: 10px; margin-bottom: 10px; }
        .label { color: #888; font-size: 12px; min-width: 120px; }
        .value { font-weight: bold; font-size: 13px; }
        .feedback { background: #f8fafc; padding: 10px; border-left: 3px solid #f59e0b; margin-bottom: 8px; }
        .stars { color: #f59e0b; }
    </style>
</head>
<body>

    <h1>{{ evenement.titre }}</h1>

    <div class="detail-row">
        <span class="label">Type</span>
        <span class="value">{{ evenement.typeEvent }}</span>
    </div>
    <div class="detail-row">
        <span class="label">Date</span>
        <span class="value">{{ evenement.dateEvent ? evenement.dateEvent|date('d/m/Y') : '—' }}</span>
    </div>
    <div class="detail-row">
        <span class="label">Lieu</span>
        <span class="value">{{ evenement.lieu ?? '—' }}</span>
    </div>
    <div class="detail-row">
        <span class="label">Statut</span>
        <span class="value">{{ evenement.statut }}</span>
    </div>
    <div class="detail-row">
        <span class="label">Description</span>
        <span class="value">{{ evenement.description }}</span>
    </div>

    {% if feedbacks is not empty %}
    <h2 style="margin-top:30px; color:#7c3aed;">Avis des employés</h2>

    {% set total = 0 %}
    {% for f in feedbacks %}{% set total = total + f.rating %}{% endfor %}
    {% set average = (total / feedbacks|length)|round(1) %}

    <p><strong>Moyenne: {{ average }}/5</strong></p>

    {% for feedback in feedbacks %}
    <div class="feedback">
        <div class="stars">
            {% for i in 1..5 %}{{ i <= feedback.rating ? '★' : '☆' }}{% endfor %}
            ({{ feedback.rating }}/5)
        </div>
        {% if feedback.commentaire %}
            <p style="margin:5px 0 0;">{{ feedback.commentaire }}</p>
        {% endif %}
        <small style="color:#888;">{{ feedback.dateFeedback ? feedback.dateFeedback|date('d/m/Y') : '' }}</small>
    </div>
    {% endfor %}
    {% endif %}

    <footer style="margin-top:40px; text-align:center; color:#888; font-size:11px;">
        STRATIX — Généré le {{ "now"|date("d/m/Y H:i") }}
    </footer>

</body>
</html>