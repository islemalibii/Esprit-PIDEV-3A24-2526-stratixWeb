{% extends 'base.html.twig' %}

{% block title %}{{ evenement.titre }}{% endblock %}

{% block body %}
<div id="overlay" class="overlay"></div>


<main id="content" class="content py-10">
    <div class="container-fluid">

        <div class="row mb-4">
            <div class="col-12 d-flex justify-content-between align-items-center">
                <div>
                    <a href="{{ path('resp_event_index') }}" class="text-muted small text-decoration-none">
                        <i class="ti ti-arrow-left me-1"></i> Retour aux événements
                    </a>
                    <h1 class="fs-4 fw-semibold text-dark mt-1 mb-0">{{ evenement.titre }}</h1>
                </div>
                <div class="d-flex gap-2">
                    <a href="{{ path('resp_event_edit', {'id': evenement.id}) }}"
                       class="btn btn-sm btn-primary px-3">
                        <i class="ti ti-pencil me-1"></i> Modifier
                    </a>
                    <a href="{{ path('resp_event_archive', {'id': evenement.id}) }}"
                       class="btn btn-sm btn-outline-secondary px-3"
                       onclick="return confirm('{{ evenement.isArchived ? 'Restaurer' : 'Archiver' }} cet événement ?')">
                        <i class="ti ti-archive me-1"></i>
                        {{ evenement.isArchived ? 'Restaurer' : 'Archiver' }}
                    </a>
                    <a href="{{ path('resp_event_pdf', {'id': evenement.id}) }}"
                    class="btn btn-sm btn-outline-danger px-3"
                    target="_blank">
                        <i class="ti ti-file-type-pdf me-1"></i> Exporter PDF
                    </a>
                    <a href="{{ path('participation_export_excel', {'id': evenement.id}) }}"
                    class="btn btn-sm btn-outline-success px-3">
                        <i class="ti ti-file-type-xls me-1"></i> Exporter Participants
                    </a>
                </div>
            </div>
        </div>

        <div class="row g-4">

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm overflow-hidden">
                    {% if evenement.imageUrl %}
                        <img src="{{ asset(evenement.imageUrl) }}"
                             alt="{{ evenement.titre }}"
                             class="w-100"
                             style="height: 280px; object-fit: cover;">
                    {% else %}
                        <div class="d-flex align-items-center justify-content-center"
                             style="height:280px; background:#ede9fe;">
                            <i class="ti ti-calendar-event" style="font-size:4rem; color:#7c3aed;"></i>
                        </div>
                    {% endif %}

                    <div class="card-body p-3 border-top d-flex justify-content-between align-items-center"
                         style="background:#fafafa;">
                        <span class="text-muted small">Statut actuel</span>
                        {% if evenement.statut == 'planifier' %}
                            <span class="badge rounded-pill fw-normal" style="background:#dcfce7;color:#16a34a;">Planifié</span>
                        {% elseif evenement.statut == 'annuler' %}
                            <span class="badge rounded-pill fw-normal" style="background:#fee2e2;color:#dc2626;">Annulé</span>
                        {% elseif evenement.statut == 'terminer' %}
                            <span class="badge rounded-pill fw-normal" style="background:#fef9c3;color:#ca8a04;">Terminé</span>
                        {% else %}
                            <span class="badge bg-secondary-subtle text-secondary rounded-pill">{{ evenement.statut ?? '—' }}</span>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">

                        <h6 class="fw-semibold text-muted text-uppercase small mb-4"
                            style="letter-spacing:.05em;">Détails de l'événement</h6>

                        <div class="row g-4">

                            <div class="col-sm-6">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="rounded-2 p-2" style="background:#ede9fe; min-width:38px; text-align:center;">
                                        <i class="ti ti-tag" style="color:#7c3aed;"></i>
                                    </div>
                                    <div>
                                        <p class="mb-0 text-muted" style="font-size:.72rem;">Type d'événement</p>
                                        {% set typeLabels = {
                                            'reunion':          ['Réunion',      '#3b82f6', '#eff6ff'],
                                            'formation':        ['Formation',    '#8b5cf6', '#f5f3ff'],
                                            'lancementProduit': ['Lancement',    '#10b981', '#ecfdf5'],
                                            'seminaire':        ['Séminaire',    '#f59e0b', '#fffbeb'],
                                            'recrutement':      ['Recrutement',  '#ef4444', '#fef2f2']
                                        } %}
                                        {% if evenement.typeEvent in typeLabels|keys %}
                                            {% set label = typeLabels[evenement.typeEvent] %}
                                            <span class="badge rounded-pill px-2 fw-normal mt-1"
                                                  style="background:{{ label[2] }};color:{{ label[1] }};">
                                                {{ label[0] }}
                                            </span>
                                        {% else %}
                                            <p class="mb-0 fw-semibold small">{{ evenement.typeEvent ?? '—' }}</p>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>

                            <div class="col-sm-6">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="rounded-2 p-2" style="background:#dcfce7; min-width:38px; text-align:center;">
                                        <i class="ti ti-calendar" style="color:#16a34a;"></i>
                                    </div>
                                    <div>
                                        <p class="mb-0 text-muted" style="font-size:.72rem;">Date</p>
                                        <p class="mb-0 fw-semibold small">
                                            {{ evenement.dateEvent ? evenement.dateEvent|date('d/m/Y') : '—' }}
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <div class="col-sm-6">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="rounded-2 p-2" style="background:#fef9c3; min-width:38px; text-align:center;">
                                        <i class="ti ti-map-pin" style="color:#ca8a04;"></i>
                                    </div>
                                    <div>
                                        <p class="mb-0 text-muted" style="font-size:.72rem;">Lieu</p>
                                        <p class="mb-0 fw-semibold small">{{ evenement.lieu ?? '—' }}</p>
                                    </div>
                                </div>
                                
                            </div>
                            {# After the existing details cards #}
                            {% if evenement.latitude and evenement.longitude %}
                            <div class="row mt-4">
                                <div class="col-12">
                                    <div class="card border-0 shadow-sm">
                                        <div class="card-body p-4">
                                            <h6 class="fw-semibold text-muted text-uppercase small mb-3"
                                                style="letter-spacing:.05em;">
                                                <i class="ti ti-map-pin me-1"></i> Localisation
                                            </h6>
                                            <div id="map-show" class="rounded-2" style="height:300px;"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
                            <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
                            <script>
                                const map = L.map('map-show', { zoomControl: true, dragging: true }).setView(
                                    [{{ evenement.latitude }}, {{ evenement.longitude }}], 14
                                );
                                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                                    attribution: '© OpenStreetMap contributors'
                                }).addTo(map);
                                L.marker([{{ evenement.latitude }}, {{ evenement.longitude }}])
                                    .addTo(map)
                                    .bindPopup('{{ evenement.lieu|e('js') }}')
                                    .openPopup();
                            </script>
                            {% endif %}
                            

                            <div class="col-12">
                                <div class="d-flex gap-3">
                                    <div class="rounded-2 p-2" style="background:#e0f2fe; min-width:38px; text-align:center; height:38px;">
                                        <i class="ti ti-file-text" style="color:#0284c7;"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <p class="mb-1 text-muted" style="font-size:.72rem;">Description</p>
                                        <p class="mb-0 text-dark small" style="line-height:1.8;">
                                            {{ evenement.description ?? 'Aucune description fournie.' }}
                                        </p>
                                    </div>
                                </div>
                            </div>


                            {% if feedbacks is not empty %}
                            
                            <div class="row mt-4">
                                <div class="col-12">
                                    <div class="card border-0 shadow-sm">
                                        <div class="card-body p-4">
                                            <h6 class="fw-semibold text-muted text-uppercase small mb-4"
                                                style="letter-spacing:.05em;">
                                                <i class="ti ti-star me-1 text-warning"></i>
                                                Avis des employés ({{ feedbacks|length }})
                                            </h6>

                                            {% set total = 0 %}
                                            {% for f in feedbacks %}{% set total = total + f.rating %}{% endfor %}
                                            {% set average = (total / feedbacks|length)|round(1) %}


                                            {% if evenement.statut == 'terminer' and feedbacks is not empty %}
                                            <div class="mt-4" id="summary-section">

                                                <button id="btn-generate-summary"
                                                        class="btn btn-sm px-3"
                                                        data-event-id="{{ evenement.id }}"
                                                        style="background:#ede9fe; color:#7c3aed; border:none;">
                                                    <i class="ti ti-sparkles me-1"></i> Générer un résumé IA
                                                </button>

                                                <div id="summary-loading" class="mt-3 d-none">
                                                    <div class="d-flex align-items-center gap-2 text-muted small">
                                                        <div class="spinner-border spinner-border-sm" style="color:#7c3aed;"></div>
                                                        <span>L'IA analyse les avis...</span>
                                                    </div>
                                                </div>

                                                <div id="summary-result" class="mt-3 d-none">
                                                    <div class="p-4 rounded-2" style="background:#f5f3ff; border-left: 4px solid #7c3aed;">
                                                        <div class="d-flex align-items-center gap-2 mb-3">
                                                            <i class="ti ti-sparkles" style="color:#7c3aed;"></i>
                                                            <span class="fw-semibold small" style="color:#7c3aed;">Résumé généré par IA</span>
                                                        </div>
                                                        <div id="summary-text" class="small text-dark" style="line-height:1.8; white-space: pre-line;"></div>
                                                    </div>
                                                </div>

                                            </div>
                                            {% endif %}

                                            <div class="d-flex flex-column gap-3">
                                                {% for feedback in feedbacks %}
                                                <div class="p-3 rounded-2" style="background:#f8fafc; border-left: 3px solid #f59e0b;">
                                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                                        <div class="d-flex gap-1">
                                                            {% for i in 1..5 %}
                                                                <i class="ti ti-star{% if i <= feedback.rating %}-filled text-warning{% else %} text-muted{% endif %} small"></i>
                                                            {% endfor %}
                                                        </div>
                                                        <span class="text-muted" style="font-size:.72rem;">
                                                            {{ feedback.dateFeedback ? feedback.dateFeedback|date('d/m/Y') : '' }}
                                                        </span>
                                                    </div>
                                                    {% if feedback.commentaire %}
                                                        <p class="mb-0 small text-dark">{{ feedback.commentaire }}</p>
                                                    {% endif %}
                                                </div>
                                                {% endfor %}
                                            </div>

                                        </div>
                                    </div>
                                </div>
                            </div>
                            {% endif %}

                        </div>
                    </div>
                </div>
            </div>

        </div>

        <footer class="text-center py-3 mt-5 text-muted small">
            Copyright © 2026 InApp Inventory Dashboard.
        </footer>

    </div>
</main>
{% if evenement.statut == 'terminer' %}
<script>
    const btnSummary = document.getElementById('btn-generate-summary');
    if (btnSummary) {
        btnSummary.addEventListener('click', function() {
            const eventId = this.dataset.eventId;
            const loading = document.getElementById('summary-loading');
            const result  = document.getElementById('summary-result');
            const text    = document.getElementById('summary-text');

            btnSummary.disabled = true;
            btnSummary.innerHTML = '<i class="ti ti-sparkles me-1"></i> Génération en cours...';
            loading.classList.remove('d-none');
            result.classList.add('d-none');

            fetch(`/responsable/evenement/${eventId}/summary`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
            })
            .then(r => r.json())
            .then(data => {
                loading.classList.add('d-none');

                if (data.success) {
                    text.textContent = data.summary;
                    result.classList.remove('d-none');

                    btnSummary.innerHTML = '<i class="ti ti-refresh me-1"></i> Régénérer le résumé';
                    btnSummary.disabled  = false;
                } else {
                    btnSummary.innerHTML = '<i class="ti ti-sparkles me-1"></i> Générer un résumé IA';
                    btnSummary.disabled  = false;
                    alert(data.message);
                }
            })
            .catch(() => {
                loading.classList.add('d-none');
                btnSummary.disabled = false;
                btnSummary.innerHTML = '<i class="ti ti-sparkles me-1"></i> Générer un résumé IA';
                alert('Une erreur est survenue.');
            });
        });
    }
</script>
{% endif %}
{% endblock %}
