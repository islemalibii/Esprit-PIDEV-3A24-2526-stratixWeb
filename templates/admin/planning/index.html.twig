{# templates/admin/planning/index.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}Gestion des Plannings{% endblock %}

{% block body %}
<main id="content" class="content py-4">
<div class="container-fluid px-4">
    
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="fas fa-calendar-alt text-primary me-2"></i> Gestion des Plannings</h1>
        <a href="{{ path('app_planning_new') }}" class="btn btn-primary">
            <i class="fas fa-plus"></i> Nouveau planning
        </a>
    </div>

    <!-- Statistiques -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary">
                <div class="card-body text-center">
                    <h2 class="display-4">{{ plannings|length }}</h2>
                    <h5>📊 Total plannings</h5>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-info">
                <div class="card-body text-center">
                    <h2 class="display-4">{{ plannings|filter(p => p.typeShift == 'MATIN')|length }}</h2>
                    <h5>☀️ MATIN</h5>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning">
                <div class="card-body text-center">
                    <h2 class="display-4">{{ plannings|filter(p => p.typeShift == 'SOIR')|length }}</h2>
                    <h5>🌆 SOIR</h5>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-dark">
                <div class="card-body text-center">
                    <h2 class="display-4">{{ plannings|filter(p => p.typeShift == 'NUIT')|length }}</h2>
                    <h5>🌙 NUIT</h5>
                </div>
            </div>
        </div>
    </div>

    <!-- Formulaire de recherche PHP -->
    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <i class="fas fa-search me-2"></i> Rechercher un planning
        </div>
        <div class="card-body">
            <form method="GET" action="{{ path('app_planning_index') }}">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label">📅 Date</label>
                        <input type="date" 
                               name="search_date" 
                               class="form-control"
                               value="{{ search_date|default('') }}">
                    </div>
                    
                    <div class="col-md-3">
                        <label class="form-label">📋 Type de shift</label>
                        <select name="search_type" class="form-select">
                            <option value="">Tous les types</option>
                            <option value="MATIN" {% if search_type == 'MATIN' %}selected{% endif %}>☀️ MATIN</option>
                            <option value="SOIR" {% if search_type == 'SOIR' %}selected{% endif %}>🌆 SOIR</option>
                            <option value="NUIT" {% if search_type == 'NUIT' %}selected{% endif %}>🌙 NUIT</option>
                            <option value="CONGE" {% if search_type == 'CONGE' %}selected{% endif %}>🏖️ CONGE</option>
                            <option value="RTT" {% if search_type == 'RTT' %}selected{% endif %}>📅 RTT</option>
                        </select>
                    </div>
                    
                    <div class="col-md-3">
                        <label class="form-label">👤 Employé</label>
                        <select name="search_employe" class="form-select">
                            <option value="">Tous les employés</option>
                            {% for id, nom in employes %}
                                <option value="{{ id }}" {% if search_employe|default('') == id|default('') %}selected{% endif %}>
                                    {{ nom }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    
                    <div class="col-md-3">
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="fas fa-search"></i> Rechercher
                            </button>
                            <a href="{{ path('app_planning_index') }}" class="btn btn-secondary">
                                <i class="fas fa-undo-alt"></i>
                            </a>
                        </div>
                    </div>
                </div>
                
                <!-- Afficher les filtres actifs -->
                {% if search_date|default('') or search_type|default('') or search_employe|default('') %}
                    <div class="mt-3">
                        <small class="text-muted">
                            <i class="fas fa-filter"></i>
                            <strong>{{ plannings|length }}</strong> résultat(s) trouvé(s)
                            {% if search_date %} - Date: <strong>{{ search_date }}</strong>{% endif %}
                            {% if search_type %} - Type: <strong>{{ search_type }}</strong>{% endif %}
                            {% if search_employe %} - Employé: <strong>{{ employes[search_employe] ?? '' }}</strong>{% endif %}
                        </small>
                    </div>
                {% endif %}
            </form>
        </div>
    </div>

    <!-- Tableau des résultats -->
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Employé</th>
                            <th>Date</th>
                            <th>Heure début</th>
                            <th>Heure fin</th>
                            <th>Type</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for planning in plannings %}
                        <tr>
                            <td>{{ planning.id }}</td>
                            <td>{{ employes[planning.employeId] ?? 'Non assigné' }}</td>
                            <td class="{% if planning.date and planning.date < date() %}text-danger{% endif %}">
                                {{ planning.date ? planning.date|date('d/m/Y') : '-' }}
                                {% if planning.date and planning.date < date() %}
                                    <i class="fas fa-exclamation-triangle" title="Date passée"></i>
                                {% endif %}
                            </td>
                            <td>{{ planning.heureDebut ? planning.heureDebut|date('H:i') : '-' }}</td>
                            <td>{{ planning.heureFin ? planning.heureFin|date('H:i') : '-' }}</td>
                            <td>
                                {% if planning.typeShift == 'MATIN' %}
                                    <span class="badge bg-info">☀️ MATIN</span>
                                {% elseif planning.typeShift == 'SOIR' %}
                                    <span class="badge bg-warning">🌆 SOIR</span>
                                {% elseif planning.typeShift == 'NUIT' %}
                                    <span class="badge bg-dark">🌙 NUIT</span>
                                {% elseif planning.typeShift == 'CONGE' %}
                                    <span class="badge bg-warning text-dark">🏖️ CONGE</span>
                                {% elseif planning.typeShift == 'RTT' %}
                                    <span class="badge bg-secondary">📅 RTT</span>
                                {% else %}
                                    <span class="badge bg-secondary">{{ planning.typeShift }}</span>
                                {% endif %}
                            </td>
                            <td class="table-actions">
                                <div class="btn-group btn-group-sm">
                                    <a href="{{ path('app_planning_show', {'id': planning.id}) }}" class="btn btn-outline-info" title="Voir">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="{{ path('app_planning_edit', {'id': planning.id}) }}" class="btn btn-outline-warning" title="Modifier">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_planning_delete', {'id': planning.id}) }}" style="display:inline-block" onsubmit="return confirm('Supprimer ce planning ?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ planning.id) }}">
                                        <button class="btn btn-outline-danger" title="Supprimer">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        {% else %}
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="fas fa-calendar-times fa-3x mb-3 d-block"></i>
                                    Aucun planning trouvé
                                    {% if search_date|default('') or search_type|default('') or search_employe|default('') %}
                                        — <a href="{{ path('app_planning_index') }}">Réinitialiser les filtres</a>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
</main>

<style>
    .table-actions .btn { padding: 2px 8px; margin: 0 2px; }
    .badge { font-size: 0.85rem; padding: 5px 10px; border-radius: 20px; }
    .card { border-radius: 15px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
    .card-header { border-radius: 15px 15px 0 0; }
    .btn-group .btn { margin: 0 1px; }
</style>
{% endblock %}