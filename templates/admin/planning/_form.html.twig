{{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
<main id="content" class="content py-4">
<div class="container-fluid px-4">
<div class="card">
    <div class="card-header bg-success text-white">
        <h5 class="mb-0"><i class="fas fa-plus-circle"></i> {{ button_label|default('Nouveau planning') }}</h5>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6 mb-3">
                {{ form_label(form.employe_id, 'Employé *', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.employe_id, {'attr': {'class': 'form-select'}}) }}
                {{ form_errors(form.employe_id) }}
            </div>
            
            <div class="col-md-6 mb-3">
                {{ form_label(form.date, 'Date *', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.date, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.date) }}
            </div>
            
            <div class="col-md-6 mb-3">
                {{ form_label(form.heure_debut, 'Heure début *', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.heure_debut, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.heure_debut) }}
            </div>
            
            <div class="col-md-6 mb-3">
                {{ form_label(form.heure_fin, 'Heure fin *', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.heure_fin, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.heure_fin) }}
            </div>
            
            <div class="col-md-12 mb-3">
                {{ form_label(form.type_shift, 'Type de shift *', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                {{ form_widget(form.type_shift, {'attr': {'class': 'form-select'}}) }}
                {{ form_errors(form.type_shift) }}
            </div>
        </div>
    </div>
    <div class="card-footer d-flex justify-content-between">
        <button type="submit" class="btn btn-success">
            <i class="fas fa-save"></i> {{ button_label|default('Enregistrer') }}
        </button>
        <a href="{{ path('app_planning_index') }}" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Retour à la liste
        </a>
    </div>
</div>
</div>
</main>
{{ form_end(form) }}