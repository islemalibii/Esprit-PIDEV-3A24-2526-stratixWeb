{% extends 'base.html.twig' %}

{% block title %}Détail du Planning{% endblock %}

{% block body %}
<main id="content" class="content py-4">
<div class="container-fluid px-4">
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="fas fa-calendar-alt"></i> Détail du Planning</h1>
    <a href="{{ path('app_planning_index') }}" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Retour à la liste
    </a>
</div>

<div class="card">
    <div class="card-header bg-success text-white">
        <h5 class="mb-0"><i class="fas fa-info-circle"></i> Informations du planning</h5>
    </div>
    <div class="card-body">
        <table class="table table-bordered">
            <tr>
                <th style="width: 30%">Employé</th>
                <td>{{ employes[planning.employeId] ?? 'Non assigné' }}</td>
            </tr>
            <tr>
                <th>Date</th>
                <td>{{ planning.date ? planning.date|date('d/m/Y') : '-' }}</td>
            </tr>
            <tr>
                <th>Heure début</th>
                <td>{{ planning.heureDebut ? planning.heureDebut|date('H:i') : '-' }}</td>
            </tr>
            <tr>
                <th>Heure fin</th>
                <td>{{ planning.heureFin ? planning.heureFin|date('H:i') : '-' }}</td>
            </tr>
            <tr>
                <th>Type de shift</th>
                <td>
                    {% if planning.typeShift == 'JOUR' %}
                        <span class="badge bg-info">☀️ JOUR</span>
                    {% elseif planning.typeShift == 'SOIR' %}
                        <span class="badge bg-warning">🌆 SOIR</span>
                    {% elseif planning.typeShift == 'NUIT' %}
                        <span class="badge bg-dark">🌙 NUIT</span>
                    {% elseif planning.typeShift == 'CONGE' %}
                        <span class="badge bg-warning text-dark">🏖️ CONGÉ</span>
                    {% elseif planning.typeShift == 'MALADIE' %}
                        <span class="badge bg-danger">🤒 MALADIE</span>
                    {% elseif planning.typeShift == 'FORMATION' %}
                        <span class="badge bg-info">📚 FORMATION</span>
                    {% else %}
                        <span class="badge bg-secondary">⚪ AUTRE</span>
                    {% endif %}
                </td>
            </tr>
        </table>
    </div>
    <div class="card-footer d-flex gap-2">
        <a href="{{ path('app_planning_edit', {'id': planning.id}) }}" class="btn btn-warning">
            <i class="fas fa-edit"></i> Modifier
        </a>
        <form method="post" action="{{ path('app_planning_delete', {'id': planning.id}) }}" onsubmit="return confirm('Supprimer ce planning ?')">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ planning.id) }}">
            <button class="btn btn-danger">
                <i class="fas fa-trash"></i> Supprimer
            </button>
        </form>
    </div>
</div>
</div>
</main>
{% endblock %}