{% extends 'base.html.twig' %}

{% block title %}Gestion des Tâches{% endblock %}

{% block body %}
<main id="content" class="content py-4">
<div class="container-fluid px-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="fas fa-tasks"></i> Gestion des Tâches</h1>
        <div>
            <button onclick="toggleStats()" class="btn btn-info me-2" id="statsBtn">
                <i class="fas fa-chart-line"></i> Afficher Statistiques
            </button>
            <a href="/api/export/taches" class="btn btn-danger me-2" target="_blank">
                <i class="fas fa-file-pdf"></i> Exporter PDF
            </a>
            <a href="{{ path('app_tache_new') }}" class="btn btn-primary">
                <i class="fas fa-plus"></i> Nouvelle tâche
            </a>
        </div>
    </div>

    <!-- SECTION STATISTIQUES -->
    <div id="statsSection" style="display: none;">
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card text-white bg-primary">
                    <div class="card-body text-center">
                        <h2 class="display-4">{{ total }}</h2>
                        <h5>📊 Total tâches</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-info">
                    <div class="card-body text-center">
                        <h2 class="display-4">{{ en_cours }}</h2>
                        <h5>⚡ En cours</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-success">
                    <div class="card-body text-center">
                        <h2 class="display-4">{{ terminees }}</h2>
                        <h5>✅ Terminées</h5>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-warning">
                    <div class="card-body text-center">
                        <h2 class="display-4">{{ a_faire }}</h2>
                        <h5>📌 À faire</h5>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-primary text-white">
                        <i class="fas fa-chart-pie"></i> Répartition par Statut
                    </div>
                    <div class="card-body text-center">
                        <canvas id="statutChart" width="300" height="300"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-primary text-white">
                        <i class="fas fa-chart-bar"></i> Répartition par Priorité
                    </div>
                    <div class="card-body text-center">
                        <canvas id="prioriteChart" width="300" height="300"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <i class="fas fa-trophy"></i> Taux de Complétion
                    </div>
                    <div class="card-body text-center">
                        <h1 class="display-1 text-success">{{ taux_completion }}%</h1>
                        <div class="progress mt-3" style="height: 30px;">
                            <div class="progress-bar bg-success progress-bar-striped" style="width: {{ taux_completion }}%">
                                {{ taux_completion }}%
                            </div>
                        </div>
                        <p class="mt-3">
                            <i class="fas fa-check-circle text-success"></i> {{ terminees }} / {{ total }} tâches terminées
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ===== FILTRES : pure GET form, no JS, URL changes ===== #}
    <div class="card mb-4">
        <div class="card-body">
            <form method="GET" action="{{ path('app_tache_index') }}">
                <div class="row g-3 align-items-center">
                    <div class="col-md-5">
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-search"></i></span>
                            <input type="text"
                                   name="search"
                                   class="form-control"
                                   placeholder="Rechercher une tâche..."
                                   value="{{ search }}">
                        </div>
                    </div>
                    <div class="col-md-3">
                        <select name="statut" class="form-select" onchange="this.form.submit()">
                            <option value="">Tous les statuts</option>
                            <option value="A_FAIRE"  {{ statut == 'A_FAIRE'  ? 'selected' : '' }}>📌 À faire</option>
                            <option value="EN_COURS" {{ statut == 'EN_COURS' ? 'selected' : '' }}>⚡ En cours</option>
                            <option value="TERMINEE" {{ statut == 'TERMINEE' ? 'selected' : '' }}>✅ Terminée</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <select name="priorite" class="form-select" onchange="this.form.submit()">
                            <option value="">Priorité</option>
                            <option value="HAUTE"   {{ priorite == 'HAUTE'   ? 'selected' : '' }}>🔴 Haute</option>
                            <option value="MOYENNE" {{ priorite == 'MOYENNE' ? 'selected' : '' }}>🟡 Moyenne</option>
                            <option value="BASSE"   {{ priorite == 'BASSE'   ? 'selected' : '' }}>🟢 Basse</option>
                        </select>
                    </div>
                    <div class="col-md-2 d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-grow-1">
                            <i class="fas fa-search"></i> Rechercher
                        </button>
                        <a href="{{ path('app_tache_index') }}" class="btn btn-outline-secondary" title="Réinitialiser">
                            <i class="fas fa-undo-alt"></i>
                        </a>
                    </div>
                </div>

                {% if search or statut or priorite %}
                <div class="mt-2">
                    <small class="text-muted">
                        <i class="fas fa-filter"></i>
                        <strong>{{ taches|length }}</strong> résultat(s)
                        {% if search %} pour "<strong>{{ search }}</strong>"{% endif %}
                        {% if statut %} — statut : <strong>{{ statut }}</strong>{% endif %}
                        {% if priorite %} — priorité : <strong>{{ priorite }}</strong>{% endif %}
                        &nbsp;·&nbsp; <a href="{{ path('app_tache_index') }}">Effacer les filtres</a>
                    </small>
                </div>
                {% endif %}
            </form>
        </div>
    </div>

    <!-- Tableau des tâches -->
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Titre</th>
                            <th>Description</th>
                            <th>Deadline</th>
                            <th>Statut</th>
                            <th>Priorité</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for tache in taches %}
                        <tr>
                            <td><strong>{{ tache.titre }}</strong></td>
                            <td>{{ tache.description|slice(0, 50) }}{% if tache.description|length > 50 %}...{% endif %}</td>
                            <td class="{% if tache.deadline and tache.deadline|date('Y-m-d') < 'now'|date('Y-m-d') and tache.statut != 'TERMINEE' %}text-danger fw-bold{% endif %}">
                                {% if tache.deadline and tache.deadline|date('Y-m-d') < 'now'|date('Y-m-d') and tache.statut != 'TERMINEE' %}
                                    <i class="fas fa-exclamation-triangle"></i>
                                {% else %}
                                    <i class="fas fa-calendar-alt"></i>
                                {% endif %}
                                {{ tache.deadline ? tache.deadline|date('d/m/Y') : '—' }}
                            </td>
                            <td>
                                {% if tache.statut == 'A_FAIRE' %}
                                    <span class="badge bg-warning text-dark">📌 À faire</span>
                                {% elseif tache.statut == 'EN_COURS' %}
                                    <span class="badge bg-info">⚡ En cours</span>
                                {% else %}
                                    <span class="badge bg-success">✅ Terminée</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if tache.priorite == 'HAUTE' %}
                                    <span class="badge bg-danger">🔴 Haute</span>
                                {% elseif tache.priorite == 'MOYENNE' %}
                                    <span class="badge bg-warning text-dark">🟡 Moyenne</span>
                                {% else %}
                                    <span class="badge bg-secondary">🟢 Basse</span>
                                {% endif %}
                            </td>
                            <td class="table-actions">
                                <div class="btn-group btn-group-sm">
                                    <a href="{{ path('app_tache_show', {'id': tache.id}) }}" class="btn btn-outline-info" title="Voir">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="{{ path('app_tache_edit', {'id': tache.id}) }}" class="btn btn-outline-warning" title="Modifier">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="/api/export/tache/{{ tache.id }}" class="btn btn-outline-danger" title="PDF" target="_blank">
                                        <i class="fas fa-file-pdf"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_tache_delete', {'id': tache.id}) }}" style="display:inline-block" onsubmit="return confirm('Supprimer cette tâche ?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tache.id) }}">
                                        <button class="btn btn-outline-danger" title="Supprimer">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    <i class="fas fa-search fa-2x mb-2 d-block"></i>
                                    Aucune tâche trouvée
                                    {% if search or statut or priorite %}
                                        — <a href="{{ path('app_tache_index') }}">Effacer les filtres</a>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
</main>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
// Only stats toggle — zero filtering JS
let statutChart, prioriteChart, statsVisible = false;

function toggleStats() {
    const s = document.getElementById('statsSection');
    const b = document.getElementById('statsBtn');
    statsVisible = !statsVisible;
    s.style.display = statsVisible ? 'block' : 'none';
    b.innerHTML = statsVisible
        ? '<i class="fas fa-chart-line"></i> Masquer Statistiques'
        : '<i class="fas fa-chart-line"></i> Afficher Statistiques';
    if (statsVisible) setTimeout(createCharts, 100);
}

function createCharts() {
    const sc = document.getElementById('statutChart')?.getContext('2d');
    if (sc && !statutChart) {
        statutChart = new Chart(sc, {
            type: 'doughnut',
            data: {
                labels: ['À faire', 'En cours', 'Terminées'],
                datasets: [{ data: [{{ a_faire }}, {{ en_cours }}, {{ terminees }}], backgroundColor: ['#ffc107', '#0dcaf0', '#198754'], borderWidth: 0 }]
            },
            options: { responsive: true, maintainAspectRatio: true, plugins: { legend: { position: 'bottom' } } }
        });
    }
    const pc = document.getElementById('prioriteChart')?.getContext('2d');
    if (pc && !prioriteChart) {
        prioriteChart = new Chart(pc, {
            type: 'doughnut',
            data: {
                labels: ['Haute', 'Moyenne', 'Basse'],
                datasets: [{ data: [{{ haute }}, {{ moyenne }}, {{ basse }}], backgroundColor: ['#dc3545', '#ffc107', '#198754'], borderWidth: 0 }]
            },
            options: { responsive: true, maintainAspectRatio: true, plugins: { legend: { position: 'bottom' } } }
        });
    }
}
</script>

<style>
    .table-actions .btn { padding: 2px 8px; margin: 0 2px; }
    .badge { font-size: 0.85rem; padding: 5px 10px; border-radius: 20px; }
    .card { border-radius: 15px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
    .card-header { border-radius: 15px 15px 0 0; }
    .progress-bar { transition: width 0.5s ease; }
    .btn-group .btn { margin: 0 1px; }
    #statsSection { transition: all 0.3s ease; }
</style>
{% endblock %}
