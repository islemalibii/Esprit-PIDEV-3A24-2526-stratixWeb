<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="filter-card">
            <div class="filter-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="fas fa-sliders-h me-2 text-orange"></i>Filtres</h6>
                <button type="button" class="btn btn-sm btn-link text-muted" id="toggleAdvancedFilters">
                    <i class="fas fa-chevron-down me-1"></i> Avancé
                </button>
            </div>
            <div class="filter-body">
                <div class="row g-3 mb-3">
                    <div class="col-md-5">
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="fas fa-search text-muted"></i></span>
                            <input type="text" id="quickKeyword" class="form-control filter-input" placeholder="Rechercher par titre ou description...">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <select id="quickCategorie" class="form-select filter-select">
                            <option value="">Toutes catégories</option>
                            {% for categorie in categories %}
                                <option value="{{ categorie.nom }}">{{ categorie.nom }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button type="button" class="btn btn-secondary-outline w-100" id="resetFiltersBtn">
                            <i class="fas fa-undo-alt me-2"></i>Réinitialiser
                        </button>
                    </div>
                </div>

                <!-- Advanced filters (collapsible) -->
                <div id="advancedFilters" style="display: none;">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label small text-muted">Budget min (DT)</label>
                            <input type="number" id="budgetMin" class="form-control filter-input" placeholder="0" step="1000">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small text-muted">Budget max (DT)</label>
                            <input type="number" id="budgetMax" class="form-control filter-input" placeholder="Illimité" step="1000">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small text-muted">Date de début après</label>
                            <input type="date" id="dateStart" class="form-control filter-input">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small text-muted">Date de fin avant</label>
                            <input type="date" id="dateEnd" class="form-control filter-input">
                        </div>
                        <div class="col-md-3">
                            <div class="form-check mt-4">
                                <input class="form-check-input" type="checkbox" id="showArchive">
                                <label class="form-check-label text-muted" for="showArchive">
                                    <i class="fas fa-archive me-1"></i>Inclure les archives
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="activeFiltersTags" class="mt-3 d-flex flex-wrap gap-2"></div>
            </div>
        </div>
    </div>
</div>