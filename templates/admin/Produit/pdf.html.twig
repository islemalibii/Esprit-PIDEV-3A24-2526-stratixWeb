<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: sans-serif; }
        .header { text-align: center; color: #764ba2; margin-bottom: 30px; }
        table { width: 100%; border-collapse: collapse; }
        th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
        th { background-color: #667eea; color: white; }
        .footer { margin-top: 20px; font-size: 10px; text-align: right; }
    </style>
</head>
<body>
    <div class="header">
        <h1>Rapport d'Inventaire Stratix</h1>
        <p>Généré le {{ "now"|date("d/m/Y H:i") }}</p>
    </div>

    <table>
        <thead>
            <tr>
                <th>Nom</th>
                <th>Prix</th>
                <th>Stock Actuel</th>
                <th>Valeur</th>
            </tr>
        </thead>
        <tbody>
            {% for produit in produits %}
                <tr>
                    <td>{{ produit.nom }}</td>
                    <td>{{ produit.prix }} DT</td>
                    <td>{{ produit.stockActuel }}</td>
                    <td>{{ produit.prix * produit.stockActuel }} DT</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="footer">
        Document officiel généré par le système Stratix.
    </div>
</body>
</html>