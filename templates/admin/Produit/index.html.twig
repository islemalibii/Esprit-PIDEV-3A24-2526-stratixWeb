{# templates/admin/produit/index.html.twig #}

{% extends 'admin/base_admin.html.twig' %}

{% block title %}Stratix - Liste des Produits{% endblock %}

{% block admin_content %}

<div class="container-fluid mt-4"> 
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            
            {# BARRE DE RECHERCHE #}
            <form method="GET" action="{{ path('produit_index') }}" class="row g-2 mb-4">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">🔍</span>
                        <input type="text" name="q" value="{{ searchTerm }}" class="form-control border-start-0" placeholder="Rechercher un produit (nom, catégorie...)...">
                    </div>
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn text-white" style="background-color: #3498db;">Rechercher</button>
                    <a href="{{ path('produit_index') }}" class="btn text-white" style="background-color: #95a5a6;">Effacer</a>
                </div>
            </form>

            {# ENTÊTE ET ACTIONS #}
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="h4 mb-0 fw-bold" style="color: #2c3e50;">Gestion des Produits</h2>
                <div class="d-flex gap-2">
                    <div class="dropdown">
                        <button class="btn text-white dropdown-toggle" type="button" data-bs-toggle="dropdown" style="background-color: #9b59b6;">
                            🔽 Trier par
                        </button>
                        <ul class="dropdown-menu shadow border-0">
                            <li><a class="dropdown-item" href="{{ path('produit_index', {sort: 'prix', direction: 'asc'}) }}">Prix croissant</a></li>
                            <li><a class="dropdown-item" href="{{ path('produit_index', {sort: 'prix', direction: 'desc'}) }}">Prix décroissant</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="{{ path('produit_index', {sort: 'nom', direction: 'asc'}) }}">Nom (A-Z)</a></li>
                        </ul>
                    </div>
                    <a href="{{ path('produit_new') }}" class="btn text-white fw-bold" style="background-color: #27ae60;">➕ Nouveau Produit</a>
                    <a href="{{ path('produit_pdf') }}" class="btn btn-danger shadow-sm">Export PDF 📄</a>
                </div>
            </div>

            {# TABLEAU #}
            <div class="table-responsive rounded border shadow-sm bg-white">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Produit</th>
                            <th>Prix</th>
                            <th>Stock Actuel</th>
                            <th>Statut</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for produit in produits %}
                            <tr>
                                <td>
                                    <div class="fw-bold text-dark">{{ produit.nom }}</div>
                                    <small class="text-muted text-uppercase" style="font-size: 0.75rem;">{{ produit.categorie }}</small>
                                </td>
                                <td class="fw-bold text-primary">{{ produit.prix|number_format(2, ',', ' ') }} DT</td>
                                <td>
                                    <span class="fw-semibold">{{ produit.stockActuel }}</span> 
                                    <small class="text-muted d-block" style="font-size: 0.7rem;">min: {{ produit.stockMin }}</small>
                                </td>
                                <td>
                                    <span class="badge {{ (produit.stockActuel <= produit.stockMin) ? 'bg-danger' : 'bg-success' }} p-2">
                                        {{ (produit.stockActuel <= produit.stockMin) ? 'Alerte Stock' : 'Disponible' }}
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group shadow-sm">
                                        <a href="{{ path('produit_edit', {id: produit.id}) }}" class="btn btn-sm btn-outline-warning" title="Modifier">✏</a>
                                        <form method="post" action="{{ path('produit_delete', {id: produit.id}) }}" style="display:inline-block;" onsubmit="return confirm('Voulez-vous vraiment supprimer ce produit ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ produit.id) }}">
                                            <button class="btn btn-sm btn-outline-danger" title="Supprimer">🗑</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted fst-italic">Aucun produit ne correspond à votre recherche.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {# STATISTIQUES (Footer) #}
            <div class="row g-0 text-center mt-4 p-3 border rounded shadow-sm" style="background-color: #f8f9fa;">
                <div class="col-md-4 border-end border-2">
                    <div class="small text-muted mb-1 text-uppercase fw-bold" style="letter-spacing: 1px;">Total Produits</div>
                    <div class="fw-bold h4 mb-0 text-dark">{{ stats.total|default(0) }}</div>
                </div>
                <div class="col-md-4 border-end border-2">
                    <div class="small text-muted mb-1 text-uppercase fw-bold" style="letter-spacing: 1px;">Stock Faible</div>
                    <div class="fw-bold h4 mb-0 text-danger">{{ stats.stockFaible|default(0) }}</div>
                </div>
                <div class="col-md-4">
                    <div class="small text-muted mb-1 text-uppercase fw-bold" style="letter-spacing: 1px;">Valeur du Stock</div>
                    <div class="fw-bold h4 mb-0 text-success">{{ stats.valeurStock|default(0)|number_format(2, ',', ' ') }} DT</div>
                </div>
            </div>

        </div>
    </div>
</div>

{# --- CHATBOT IA PRODUITS (GROK NODE) --- #}
<div id="chat-wrapper">
    <div class="card chat-card shadow-lg border-0">
        <div class="chat-header d-flex justify-content-between align-items-center" onclick="toggleChat()" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); cursor: pointer; padding: 12px 15px; border-radius: 12px 12px 0 0;">
            <div class="d-flex align-items-center text-white">
                <div class="bg-white rounded-circle p-1 me-2 shadow-sm d-flex align-items-center justify-content-center" style="width: 30px; height: 30px;">
                    <i class="ti ti-robot text-success fs-5"></i>
                </div>
                <span class="fw-bold">Expert Stratix Produits</span>
            </div>
            <i id="chat-chevron" class="ti ti-chevron-up text-white"></i>
        </div>
        
        <div id="chat-content" style="display: none; background: white;">
            <div id="chat-body" style="height: 320px; overflow-y: auto; background: #f9fafb; padding: 15px; display: flex; flex-direction: column; gap: 10px;">
                <div class="msg-bot">
                    Bonjour Rahma ! Je suis Grok, votre assistant IA. Je connais parfaitement votre inventaire actuel. Comment puis-je vous aider ?
                </div>
            </div>
            <div class="p-3 border-top bg-white">
                <div class="input-group shadow-sm rounded-pill overflow-hidden border">
                    <input type="text" id="chat-input" class="form-control border-0 bg-light px-3" 
                           placeholder="Ex: Quel produit manque ?" onkeypress="if(event.key==='Enter') sendChatMessage()">
                    <button id="chat-send-btn" class="btn btn-success border-0 px-3" onclick="sendChatMessage()">
                        <i class="ti ti-send"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    #chat-wrapper { position: fixed; bottom: 25px; right: 25px; z-index: 9999; width: 340px; }
    .chat-card { border-radius: 12px; overflow: hidden; }
    .msg-user, .msg-bot { padding: 10px 14px; border-radius: 15px; font-size: 0.85rem; max-width: 85%; line-height: 1.4; position: relative; word-wrap: break-word; }
    .msg-user { background: #10b981; color: white; align-self: flex-end; border-bottom-right-radius: 2px; }
    .msg-bot { background: white; color: #1f2937; align-self: flex-start; border-bottom-left-radius: 2px; border: 1px solid #e5e7eb; }
    .typing-dot { height: 6px; width: 6px; background: #10b981; border-radius: 50%; display: inline-block; animation: blink 1s infinite; margin: 0 2px; }
    @keyframes blink { 0%, 100% { opacity: 0.3; } 50% { opacity: 1; } }
</style>

<script>
    function toggleChat() {
        const content = document.getElementById('chat-content');
        const icon = document.getElementById('chat-chevron');
        if (content.style.display === 'none') {
            content.style.display = 'block';
            icon.className = 'ti ti-chevron-down text-white';
            const body = document.getElementById('chat-body');
            body.scrollTop = body.scrollHeight;
        } else {
            content.style.display = 'none';
            icon.className = 'ti ti-chevron-up text-white';
        }
    }

    async function sendChatMessage() {
        const input = document.getElementById('chat-input');
        const btn = document.getElementById('chat-send-btn');
        const body = document.getElementById('chat-body');
        const text = input.value.trim();
        
        if (!text) return;

        // Désactiver l'entrée pendant le chargement
        input.disabled = true;
        btn.disabled = true;

        // Ajouter message utilisateur
        body.innerHTML += `<div class="msg-user">${text}</div>`;
        input.value = '';
        body.scrollTop = body.scrollHeight;

        // Afficher Loader
        const loaderId = 'loader-' + Date.now();
        body.innerHTML += `
            <div class="msg-bot" id="${loaderId}">
                <span class="typing-dot"></span><span class="typing-dot"></span><span class="typing-dot"></span>
            </div>`;
        body.scrollTop = body.scrollHeight;

        try {
            const response = await fetch("{{ path('produit_chat') }}", {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ question: text })
            });

            if (!response.ok) throw new Error('Erreur serveur');

            const data = await response.json();
            document.getElementById(loaderId).innerText = data.reponse;
        } catch (e) {
            document.getElementById(loaderId).innerText = "Désolé Rahma, je n'arrive pas à me connecter au serveur de Stratix.";
            console.error(e);
        } finally {
            input.disabled = false;
            btn.disabled = false;
            input.focus();
            body.scrollTop = body.scrollHeight;
        }
    }
</script>

{% endblock %}