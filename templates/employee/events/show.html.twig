{% extends 'employee/base_employee.html.twig' %}

{% block title %}{{ evenement.titre }}{% endblock %}

{% block employee_content %}
<div class="container-fluid">

    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <div>
                <a href="{{ path('emp_event_list') }}" class="text-muted small text-decoration-none">
                    <i class="ti ti-arrow-left me-1"></i> Retour aux événements
                </a>
                <h1 class="fs-4 fw-semibold text-dark mt-1 mb-0">{{ evenement.titre }}</h1>
            </div>

            {# 👇 Participer / Annuler buttons #}
            <div class="d-flex gap-2" id="action-buttons">
                {% if evenement.statut == 'planifier' %}
                    {% if alreadyJoined %}
                        <button id="btn-cancel"
                            class="btn btn-sm btn-outline-danger px-3"
                            data-event-id="{{ evenement.id }}">
                            <i class="ti ti-x me-1"></i> Annuler participation
                        </button>
                        <span class="badge bg-success align-self-center px-3 py-2">
                            <i class="ti ti-check me-1"></i> Vous participez
                        </span>
                    {% else %}
                        <button id="btn-participate"
                            class="btn btn-sm btn-primary px-3"
                            data-event-id="{{ evenement.id }}">
                            <i class="ti ti-calendar-plus me-1"></i> Participer
                        </button>
                    {% endif %}
                {% endif %}
            </div>
        </div>
    </div>

    {# Message area #}
    <div id="action-msg" class="mb-3"></div>

    <div class="row g-4">

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm overflow-hidden">
                {% if evenement.imageUrl %}
                    <img src="{{ asset(evenement.imageUrl) }}"
                         alt="{{ evenement.titre }}"
                         class="w-100"
                         style="height: 280px; object-fit: cover;">
                {% else %}
                    <div class="d-flex align-items-center justify-content-center"
                         style="height:280px; background:#ede9fe;">
                        <i class="ti ti-calendar-event" style="font-size:4rem; color:#7c3aed;"></i>
                    </div>
                {% endif %}

                <div class="card-body p-3 border-top d-flex justify-content-between align-items-center"
                     style="background:#fafafa;">
                    <span class="text-muted small">Statut actuel</span>
                    {% if evenement.statut == 'planifier' %}
                        <span class="badge rounded-pill fw-normal" style="background:#dcfce7;color:#16a34a;">Planifié</span>
                    {% elseif evenement.statut == 'annuler' %}
                        <span class="badge rounded-pill fw-normal" style="background:#fee2e2;color:#dc2626;">Annulé</span>
                    {% elseif evenement.statut == 'terminer' %}
                        <span class="badge rounded-pill fw-normal" style="background:#fef9c3;color:#ca8a04;">Terminé</span>
                    {% endif %}
                </div>
            </div>

            {# 👇 Participation status card #}
            {% if alreadyJoined %}
            <div class="card border-0 shadow-sm mt-3" style="border-left: 4px solid #16a34a !important;">
                <div class="card-body p-3 d-flex align-items-center gap-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width:40px;height:40px;background:#dcfce7;">
                        <i class="ti ti-check" style="color:#16a34a;"></i>
                    </div>
                    <div>
                        <p class="mb-0 fw-semibold small text-dark">Vous participez à cet événement</p>
                        <p class="mb-0 text-muted" style="font-size:.72rem;">Un email de confirmation vous a été envoyé</p>
                    </div>
                </div>
            </div>
            {% endif %}
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <h6 class="fw-semibold text-muted text-uppercase small mb-4"
                        style="letter-spacing:.05em;">Détails de l'événement</h6>

                    <div class="row g-4">
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-2 p-2" style="background:#ede9fe; min-width:38px; text-align:center;">
                                    <i class="ti ti-tag" style="color:#7c3aed;"></i>
                                </div>
                                <div>
                                    <p class="mb-0 text-muted" style="font-size:.72rem;">Type d'événement</p>
                                    {% set typeLabels = {
                                        'reunion':          ['Réunion',      '#3b82f6', '#eff6ff'],
                                        'formation':        ['Formation',    '#8b5cf6', '#f5f3ff'],
                                        'lancementProduit': ['Lancement',    '#10b981', '#ecfdf5'],
                                        'seminaire':        ['Séminaire',    '#f59e0b', '#fffbeb'],
                                        'recrutement':      ['Recrutement',  '#ef4444', '#fef2f2']
                                    } %}
                                    {% if evenement.typeEvent in typeLabels|keys %}
                                        {% set label = typeLabels[evenement.typeEvent] %}
                                        <span class="badge rounded-pill px-2 fw-normal mt-1"
                                              style="background:{{ label[2] }};color:{{ label[1] }};">
                                            {{ label[0] }}
                                        </span>
                                    {% endif %}
                                </div>
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-2 p-2" style="background:#dcfce7; min-width:38px; text-align:center;">
                                    <i class="ti ti-calendar" style="color:#16a34a;"></i>
                                </div>
                                <div>
                                    <p class="mb-0 text-muted" style="font-size:.72rem;">Date</p>
                                    <p class="mb-0 fw-semibold small">
                                        {{ evenement.dateEvent ? evenement.dateEvent|date('d/m/Y') : '—' }}
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-2 p-2" style="background:#fef9c3; min-width:38px; text-align:center;">
                                    <i class="ti ti-map-pin" style="color:#ca8a04;"></i>
                                </div>
                                <div>
                                    <p class="mb-0 text-muted" style="font-size:.72rem;">Lieu</p>
                                    <p class="mb-0 fw-semibold small">{{ evenement.lieu ?? '—' }}</p>
                                </div>
                            </div>
                        </div>
                        {% if evenement.latitude and evenement.longitude %}
                        <div class="row mt-4">
                            <div class="col-12">
                                <div class="card border-0 shadow-sm">
                                    <div class="card-body p-4">
                                        <h6 class="fw-semibold text-muted text-uppercase small mb-3"
                                            style="letter-spacing:.05em;">
                                            <i class="ti ti-map-pin me-1"></i> Localisation
                                        </h6>
                                        <p class="text-muted small mb-2">{{ evenement.lieu }}</p>
                                        <div id="map-show" class="rounded-2" style="height:300px;"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
                        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
                        <script>
                            const map = L.map('map-show').setView(
                                [{{ evenement.latitude }}, {{ evenement.longitude }}], 14
                            );
                            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                                attribution: '© OpenStreetMap contributors'
                            }).addTo(map);
                            L.marker([{{ evenement.latitude }}, {{ evenement.longitude }}])
                                .addTo(map)
                                .bindPopup('{{ evenement.lieu|e('js') }}')
                                .openPopup();
                        </script>
                        {% endif %}

                        <div class="col-12">
                            <div class="d-flex gap-3">
                                <div class="rounded-2 p-2" style="background:#e0f2fe; min-width:38px; text-align:center; height:38px;">
                                    <i class="ti ti-file-text" style="color:#0284c7;"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <p class="mb-1 text-muted" style="font-size:.72rem;">Description</p>
                                    <p class="mb-0 text-dark small" style="line-height:1.8;">
                                        {{ evenement.description ?? 'Aucune description fournie.' }}
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="text-center py-3 mt-5 text-muted small">
        Copyright © 2026 STRATIX - InApp Dashboard.
    </footer>
</div>

<script>
    const btnParticipate = document.getElementById('btn-participate');
    if (btnParticipate) {
        btnParticipate.addEventListener('click', function() {
            const eventId = this.dataset.eventId;
            const msgBox  = document.getElementById('action-msg');

            fetch(`/api/participation/join/${eventId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            })
            .then(r => r.json())
            .then(data => {
                msgBox.innerHTML = `
                    <div class="alert alert-${data.success ? 'success' : 'warning'} py-2 px-3 small">
                        ${data.message}
                    </div>`;
                if (data.success) {
                    setTimeout(() => location.reload(), 1500);
                }
            });
        });
    }

    // Annuler
    const btnCancel = document.getElementById('btn-cancel');
    if (btnCancel) {
        btnCancel.addEventListener('click', function() {
            if (!confirm('Voulez-vous vraiment annuler votre participation ?')) return;

            const eventId = this.dataset.eventId;
            const msgBox  = document.getElementById('action-msg');

            fetch(`/api/participation/cancel/${eventId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            })
            .then(r => r.json())
            .then(data => {
                msgBox.innerHTML = `
                    <div class="alert alert-${data.success ? 'success' : 'warning'} py-2 px-3 small">
                        ${data.message}
                    </div>`;
                if (data.success) {
                    setTimeout(() => location.reload(), 1500);
                }
            });
        });
    }
</script>
{% endblock %}