<nav id="topbar" class="navbar bg-white border-bottom fixed-top topbar px-3">
    <button id="toggleBtn" class="d-none d-lg-inline-flex btn btn-light btn-icon btn-sm">
        <i class="ti ti-layout-sidebar-left-expand"></i>
    </button>
    <button id="mobileBtn" class="btn btn-light btn-icon btn-sm d-lg-none me-2">
        <i class="ti ti-layout-sidebar-left-expand"></i>
    </button>

    <div class="ms-auto">
        <ul class="list-unstyled d-flex align-items-center mb-0 gap-1">

            {% for msg in app.flashes('success') %}
                <li><div class="alert alert-success py-1 px-3 mb-0 small">{{ msg }}</div></li>
            {% endfor %}

            {# Theme toggle #}
            {% if app.user %}
            <li>
                <button id="theme-toggle" class="btn btn-light btn-icon btn-sm rounded-circle" title="Mode sombre/clair">
                    <i class="ti ti-{% if app.user.theme == 'dark' %}sun{% else %}moon{% endif %}" id="theme-icon"></i>
                </button>
            </li>
            {% endif %}

            {# Notifications #}
            <li class="dropdown">
                <a class="position-relative btn btn-light btn-icon btn-sm rounded-circle"
                   data-bs-toggle="dropdown" href="#" role="button">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M10 5a2 2 0 1 1 4 0a7 7 0 0 1 4 6v3a4 4 0 0 0 2 3h-16a4 4 0 0 0 2 -3v-3a7 7 0 0 1 4 -6"/>
                        <path d="M9 17v1a3 3 0 0 0 6 0v-1"/>
                    </svg>
                </a>
                <div class="dropdown-menu dropdown-menu-end p-0" style="min-width:300px;">
                    <div class="px-3 py-2 border-bottom fw-semibold small">Notifications</div>
                    <div class="px-3 py-3 text-center text-secondary small">
                        <i class="ti ti-bell-off d-block fs-3 mb-1"></i>
                        Aucune notification
                    </div>
                </div>
            </li>

            {# Profile dropdown #}
            {% import 'macros/avatar.html.twig' as avatarMacro %}
            {% if app.user %}
            <li class="ms-2 dropdown">
                <a href="#" role="button" data-bs-toggle="dropdown"
                   class="d-flex align-items-center gap-2 text-decoration-none">
                    {{ avatarMacro.show(app.user, '34px', '.8rem') }}
                    <div class="d-none d-md-block">
                        <div class="small fw-semibold text-dark">{{ app.user.prenom }} {{ app.user.nom }}</div>
                        <div class="small text-secondary" style="font-size:.72rem;">{{ app.user.role|upper }}</div>
                    </div>
                </a>
                <div class="dropdown-menu dropdown-menu-end p-0" style="min-width:210px;">
                    <div class="d-flex gap-3 align-items-center px-3 py-3 border-bottom">
                        {{ avatarMacro.show(app.user, '42px', '1rem') }}
                        <div>
                        <div>
                            <h4 class="mb-0 small fw-semibold">{{ app.user.prenom }} {{ app.user.nom }}</h4>
                            <p class="mb-0 small text-secondary">{{ app.user.email }}</p>
                        </div>
                    </div>
                    <div class="p-2 d-flex flex-column gap-1 small">
                        <a href="{{ path('app_employee_dashboard') }}" class="dropdown-item rounded-2 py-2">
                            <i class="ti ti-home me-2"></i>Dashboard
                        </a>
                        <a href="{{ path('employee_profile') }}" class="dropdown-item rounded-2 py-2">
                            <i class="ti ti-user me-2"></i>Mon profil
                        </a>
                        <a href="{{ path('employee_profile_edit') }}" class="dropdown-item rounded-2 py-2">
                            <i class="ti ti-settings me-2"></i>Paramètres
                        </a>
                        <div class="dropdown-divider"></div>
                        <a href="{{ path('app_logout') }}" class="dropdown-item rounded-2 py-2 text-danger">
                            <i class="ti ti-logout me-2"></i>Déconnexion
                        </a>
                    </div>
                </div>
            </li>
            {% endif %}
        </ul>
    </div>
</nav>
