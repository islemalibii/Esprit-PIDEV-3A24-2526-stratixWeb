<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: 'Helvetica', sans-serif; color: #333; font-size: 12px; }
        .header { text-align: center; border-bottom: 2px solid #3b82f6; padding-bottom: 20px; position: relative; }
        
        /* Positionnement du QR Code en haut à droite */
        .qr-code-container { position: absolute; top: 0; right: 0; text-align: center; }
        .qr-code-container img { width: 70px; height: 70px; }
        .qr-code-text { font-size: 7px; color: #64748b; margin-top: 2px; }

        .project-title { color: #3b82f6; font-size: 24px; margin-top: 20px; text-transform: uppercase; }
        .section-title { background: #f8fafc; padding: 10px; font-weight: bold; margin-top: 20px; border-left: 4px solid #3b82f6; color: #1e40af; }
        
        .details { margin-top: 15px; width: 100%; border-collapse: collapse; }
        .details td, .details th { padding: 10px; border-bottom: 1px solid #eee; text-align: left; }
        .details th { background-color: #f9fafb; color: #6b7280; width: 30%; }

        .sprint-table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        .sprint-table th { background: #3b82f6; color: white; padding: 8px; font-size: 10px; }
        .sprint-table td { padding: 8px; border-bottom: 1px solid #e5e7eb; font-size: 10px; }

        .footer { position: fixed; bottom: -20px; width: 100%; text-align: center; font-size: 9px; color: #94a3b8; border-top: 1px solid #eee; padding-top: 5px; }
    </style>
</head>
<body>
    <div class="header">

        <h1>STRATIX - Rapport de Projet</h1>
        <p>Généré le {{ "now"|date("d/m/Y H:i") }}</p>
    </div>

    <h2 class="project-title">{{ projet.nom }}</h2>

    <div class="section-title">Informations Générales</div>
    <table class="details">
        <tr><th>Statut</th><td><strong>{{ projet.statut }}</strong></td></tr>
        <tr><th>Budget Estimé</th><td style="color: #059669; font-weight: bold;">{{ projet.budget|number_format(2, ',', ' ') }} DT</td></tr>
        <tr><th>Responsable</th><td>{{ projet.responsable ? projet.responsable.prenom ~ ' ' ~ projet.responsable.nom : 'Non assigné' }}</td></tr>
        <tr><th>Échéance</th><td>{{ projet.dateFin ? projet.dateFin|date('d/m/Y') : 'Non définie' }}</td></tr>
    </table>

    <div class="section-title">Description</div>
    <p style="line-height: 1.6; text-align: justify;">{{ projet.description|default('Aucune description détaillée fournie pour ce projet.') }}</p>

    <div class="section-title">Sprints du projet ({{ projet.sprints|length }})</div>
    <table class="sprint-table">
        <thead>
            <tr>
                <th style="text-align: left;">Nom du Sprint</th>
                <th>Début</th>
                <th>Fin</th>
                <th>Statut</th>
            </tr>
        </thead>
        <tbody>
            {% for sprint in projet.sprints %}
            <tr>
                <td><strong>{{ sprint.nom }}</strong></td>
                <td style="text-align: center;">{{ sprint.dateDebut|date('d/m/Y') }}</td>
                <td style="text-align: center;">{{ sprint.dateFin|date('d/m/Y') }}</td>
                <td style="text-align: center;">{{ sprint.statut }}</td>
            </tr>
            {% else %}
            <tr>
                <td colspan="4" style="text-align: center; color: #94a3b8;">Aucun sprint enregistré pour ce projet.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="footer">
        Stratix Management System - Document Officiel - Page 1/1
    </div>
</body>
</html>