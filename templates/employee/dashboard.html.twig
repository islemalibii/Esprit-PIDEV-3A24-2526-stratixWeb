{# templates/employee/dashboard.html.twig #}
{% extends 'employee/base_employee.html.twig' %}

{% block title %}Dashboard Employé{% endblock %}

{% block employee_content %}
<div class="row mb-4">
    <div class="col-12">
        <div class="card bg-gradient-primary text-white" style="background: linear-gradient(135deg, #1e3a5f 0%, #2d6a9f 100%);">
            <div class="card-body">
                <h2 class="mb-2">
                    <i class="fas fa-user-circle me-2"></i>
                    Bonjour 👋
                </h2>
                <p class="mb-0">Bienvenue sur votre espace de travail STRATIX. Voici un aperçu de vos activités.</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card stat-card bg-primary text-white shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-1 text-white-50">Total Tâches</h6>
                        <h2 class="mb-0 fw-bold">{{ total }}</h2>
                    </div>
                    <i class="fas fa-tasks fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card bg-warning text-white shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-1 text-white-50">À Faire</h6>
                        <h2 class="mb-0 fw-bold">{{ aFaire }}</h2>
                    </div>
                    <i class="fas fa-clock fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card bg-info text-white shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-1 text-white-50">En Cours</h6>
                        <h2 class="mb-0 fw-bold">{{ enCours }}</h2>
                    </div>
                    <i class="fas fa-spinner fa-spin fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card bg-success text-white shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-1 text-white-50">Terminées</h6>
                        <h2 class="mb-0 fw-bold">{{ terminees }}</h2>
                    </div>
                    <i class="fas fa-check-circle fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom-0 pt-3">
                <h5 class="mb-0"><i class="fas fa-chart-pie me-2 text-danger"></i>Répartition par Priorité</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <div class="d-flex justify-content-between mb-2">
                            <span><i class="fas fa-circle text-danger me-1 small"></i> Haute</span>
                            <span class="fw-bold">{{ haute }}</span>
                        </div>
                        <div class="progress rounded-pill mb-3" style="height: 8px;">
                            <div class="progress-bar bg-danger" style="width: {{ total > 0 ? (haute / total * 100)|round : 0 }}%"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="d-flex justify-content-between mb-2">
                            <span><i class="fas fa-circle text-warning me-1 small"></i> Moyenne</span>
                            <span class="fw-bold">{{ moyenne }}</span>
                        </div>
                        <div class="progress rounded-pill mb-3" style="height: 8px;">
                            <div class="progress-bar bg-warning" style="width: {{ total > 0 ? (moyenne / total * 100)|round : 0 }}%"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="d-flex justify-content-between mb-2">
                            <span><i class="fas fa-circle text-success me-1 small"></i> Basse</span>
                            <span class="fw-bold">{{ basse }}</span>
                        </div>
                        <div class="progress rounded-pill mb-3" style="height: 8px;">
                            <div class="progress-bar bg-success" style="width: {{ total > 0 ? (basse / total * 100)|round : 0 }}%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0 text-primary"><i class="fas fa-history me-2"></i>Tâches Récentes</h5>
                <a href="{{ path('app_employee_taches') }}" class="btn btn-sm btn-light text-primary">Voir tout</a>
            </div>
            <div class="card-body">
                {% if hasTaches and tachesRecentes|length > 0 %}
                    {% for tache in tachesRecentes %}
                    <div class="border-bottom pb-3 mb-3 last-child-no-border">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <strong class="d-block mb-1">{{ tache.titre }}</strong>
                                <small class="text-muted">
                                    <i class="fas fa-calendar-day me-1"></i>
                                    Deadline: {{ tache.deadline ? tache.deadline|date('d/m/Y') : 'Non définie' }}
                                </small>
                            </div>
                            <span class="badge {% if tache.statut == 'A_FAIRE' %}bg-warning{% elseif tache.statut == 'EN_COURS' %}bg-info{% else %}bg-success{% endif %} rounded-pill">
                                {{ tache.statut|replace({'_': ' '}) }}
                            </span>
                        </div>
                    </div>
                    {% endfor %}
                {% else %}
                    <div class="text-center py-5 text-muted">
                        <i class="fas fa-clipboard-list fa-3x mb-3 opacity-25"></i>
                        <p>Aucune tâche assignée pour le moment</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0 text-success"><i class="fas fa-calendar-alt me-2"></i>Plannings à Venir</h5>
                <a href="{{ path('app_employee_plannings') }}" class="btn btn-sm btn-light text-success">Voir tout</a>
            </div>
            <div class="card-body">
                {% if planningsAVenir is defined and planningsAVenir|length > 0 %}
                    {% for planning in planningsAVenir %}
                    <div class="border-bottom pb-3 mb-3 last-child-no-border">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <strong class="text-dark">{{ planning.typeShift|default('Travail standard') }}</strong>
                                <br>
                                <small class="text-muted">
                                    <i class="fas fa-calendar-check me-1"></i>
                                    {{ planning.date ? planning.date|date('d/m/Y') : 'Date non définie' }}
                                    {% if planning.heureDebut %}
                                        | <i class="fas fa-clock ms-1 me-1"></i>
                                        {{ planning.heureDebut|date('H:i') }} - {{ planning.heureFin ? planning.heureFin|date('H:i') : '--:--' }}
                                    {% endif %}
                                </small>
                            </div>
                            <div class="text-end">
                                <span class="badge bg-soft-success text-success border border-success px-3">Assigné</span>
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                {% else %}
                    <div class="text-center py-5 text-muted">
                        <i class="fas fa-calendar-times fa-3x mb-3 opacity-25"></i>
                        <p>Aucun planning prévu prochainement</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<style>
    .bg-soft-success { background-color: rgba(40, 167, 69, 0.1); }
    .last-child-no-border:last-child { border-bottom: 0 !important; margin-bottom: 0 !important; }
    .stat-card { transition: transform 0.2s; border: none; }
    .stat-card:hover { transform: translateY(-5px); }
</style>
{% endblock %}