{% extends 'employee/base_employee.html.twig' %}

{% block employee_content %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">Gestion des Catégories</h1>
       
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Recherche et Filtrage</h6>
        </div>
        <div class="card-body">
            <form method="GET" class="row g-3">
                <div class="col-md-9">
                    <input type="text" name="search" class="form-control" placeholder="Rechercher par nom ou description..."
                           value="{{ search }}">
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-outline-primary me-2">
                        <i class="fas fa-search"></i> Rechercher
                    </button>
                    <a href="{{ path('app_employee_categorie_index') }}" class="btn btn-outline-secondary">
                        <i class="fas fa-times"></i> Réinitialiser
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="row">
        {% for categorie in categorie_services %}
            <div class="col-xl-4 col-md-6 mb-4">
                <div class="card border-left-info shadow h-100">
                    <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                        <h6 class="m-0 font-weight-bold text-info">{{ categorie.nom }}</h6>
                        {% if categorie.archive %}
                            <span class="badge bg-secondary">Archivée</span>
                        {% else %}
                            <span class="badge bg-success">Active</span>
                        {% endif %}
                    </div>
                    <div class="card-body">
                        {% if categorie.description %}
                            <p class="text-muted mb-3">
                                {{ categorie.description|slice(0, 150) ~ (categorie.description|length > 150 ? '...' : '') }}
                            </p>
                        {% else %}
                            <p class="text-muted mb-3">Aucune description</p>
                        {% endif %}

                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                                    Créée le
                                </div>
                                <div class="text-xs text-muted">
                                    {{ categorie.dateCreation ? categorie.dateCreation|date('d/m/Y') : 'Date inconnue' }}
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer">
                        <div class="btn-group w-100" role="group">
                            <a href="{{ path('app_employee_categorie_show', {'id': categorie.id}) }}"
                               class="btn btn-sm btn-outline-info">
                                <i class="fas fa-eye"></i> Voir
                            </a>
                           
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="card">
                    <div class="card-body text-center py-5">
                        <i class="fas fa-folder-open fa-3x text-muted mb-3"></i>
                        <h5 class="text-muted">Aucune catégorie trouvée</h5>
                        <p class="text-muted">Il n'y a pas de catégories actives correspondant à vos critères.</p>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
