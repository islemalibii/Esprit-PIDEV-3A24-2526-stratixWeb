<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Stratix — Plateforme intelligente de gestion d’entreprise</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #ffffff;
            color: #0F172A;
            overflow-x: hidden;
        }

        :root {
            --primary: #0F172A;
            --green: #10B981;
            --orange: #F97316;
            --dark: #0B1120;
        }

        .navbar {
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(10px);
            padding: 1rem 0;
            transition: 0.3s;
        }

        .navbar-scrolled {
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        }

        .navbar-brand {
            font-size: 2rem;
            font-weight: 800;
        }

        .brand-text {
            background: linear-gradient(135deg, var(--green), var(--orange));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .nav-link {
            font-weight: 600;
            margin: 0 10px;
            color: #1E293B !important;
        }

        .btn-primary-stratix {
            background: linear-gradient(135deg, #0F172A, #1E293B);
            border: none;
            padding: 0.8rem 1.7rem;
            border-radius: 50px;
            color: white;
            font-weight: 600;
            transition: 0.3s;
        }

        .btn-primary-stratix:hover {
            background: linear-gradient(135deg, var(--green), #059669);
            transform: translateY(-2px);
        }

        .hero-section {
            padding: 8rem 0 5rem;
            position: relative;
            overflow: hidden;
        }

        .hero-bg {
            position: absolute;
            width: 80%;
            height: 100%;
            top: -10%;
            right: -20%;
            background: radial-gradient(circle, rgba(16,185,129,0.12), transparent);
        }

        .hero-title {
            font-size: clamp(2.8rem, 6vw, 5rem);
            font-weight: 800;
            line-height: 1.1;
            margin-bottom: 1.5rem;
        }

        .gradient-text {
            background: linear-gradient(135deg, var(--green), var(--orange));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero-subtitle {
            color: #475569;
            font-size: 1.1rem;
            line-height: 1.7;
            margin-bottom: 2rem;
        }

        .feature-list-modern {
            list-style: none;
            padding: 0;
        }

        .feature-list-modern li {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 1rem;
            font-weight: 500;
        }

        .feature-list-modern i {
            color: var(--green);
            font-size: 1.2rem;
        }

        .hero-image-container {
            border-radius: 2rem;
            overflow: hidden;
            box-shadow: 0 30px 60px rgba(0,0,0,0.12);
        }

        .hero-image-container img {
            width: 100%;
        }

        .section-title {
            font-size: clamp(2rem, 5vw, 3.2rem);
            font-weight: 800;
            margin-bottom: 1rem;
        }

        .feature-card-modern {
            background: white;
            border-radius: 2rem;
            padding: 2rem;
            border: 1px solid #EEF2F7;
            height: 100%;
            transition: 0.35s;
            box-shadow: 0 5px 15px rgba(0,0,0,0.03);
        }

        .feature-card-modern:hover {
            transform: translateY(-8px);
            border-color: var(--green);
            box-shadow: 0 20px 35px rgba(16,185,129,0.12);
        }

        .feature-icon-lg {
            width: 60px;
            height: 60px;
            border-radius: 18px;
            background: rgba(16,185,129,0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.5rem;
            font-size: 1.8rem;
            color: var(--green);
        }

        .stats-grid {
            background: var(--primary);
            border-radius: 2rem;
            padding: 3rem;
            margin-top: 5rem;
        }

        .stat-number {
            font-size: 3rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--orange), #FDBA74);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .cta-gradient {
            background: linear-gradient(135deg, #0F172A, #1E293B);
            border-radius: 2rem;
        }

        .footer-dark {
            background: #0B1120;
            color: #CBD5E1;
        }

        .footer-dark a {
            color: #94A3B8;
            text-decoration: none;
        }

        @media(max-width:768px){
            .hero-section {
                padding-top: 6rem;
            }
        }
