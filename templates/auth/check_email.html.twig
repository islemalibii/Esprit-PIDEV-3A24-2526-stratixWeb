<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Stratix — Vérifiez votre email</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', 'Plus Jakarta Sans', sans-serif;
            background: linear-gradient(135deg, #faf8f6 0%, #ffffff 50%, #eef3ed 100%);
            min-height: 100vh;
            position: relative;
            overflow-x: hidden;
        }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: 
                linear-gradient(rgba(16, 185, 129, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(16, 185, 129, 0.03) 1px, transparent 1px);
            background-size: 50px 50px;
            pointer-events: none;
        }

        body::after {
            content: '';
            position: fixed;
            top: -40%;
            right: -20%;
            width: 80%;
            height: 80%;
            background: radial-gradient(ellipse, rgba(16, 185, 129, 0.08), transparent 70%);
            pointer-events: none;
        }

        .verify-card {
            background: rgba(255, 255, 255, 0.98);
            border-radius: 2rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.35);
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .verify-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 30px 55px -12px rgba(0, 0, 0, 0.4);
        }

        .feature-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(16, 185, 129, 0.12);
            padding: 0.4rem 1rem;
            border-radius: 40px;
            font-size: 0.75rem;
            font-weight: 600;
            color: #10B981;
            letter-spacing: 0.3px;
        }

        .icon-wrapper {
            width: 80px;
            height: 80px;
            margin: 0 auto 1.5rem;
            background: linear-gradient(135deg, rgba(16, 185, 129, 0.12), rgba(16, 185, 129, 0.05));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .icon-wrapper i {
            font-size: 2.8rem;
            color: #10B981;
        }

        .alert-custom {
            border-radius: 14px;
            border: none;
            background: #FEF2F2;
            color: #991B1B;
            font-weight: 500;
            padding: 0.85rem 1rem;
        }

        .btn-outline-elegant {
            border: 1.5px solid #E2E8F0;
            border-radius: 14px;
            padding: 0.85rem 1.8rem;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.25s;
            background: white;
            color: #1E293B;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

        .btn-outline-elegant:hover {
            background: #F8FAFE;
            border-color: #10B981;
            color: #10B981;
            transform: translateY(-2px);
        }

        @media (max-width: 640px) {
            .verify-card { margin: 1rem; }
            .verify-card .p-md-5 { padding: 2rem !important; }
        }
    </style>
</head>
<body>

<div style="position:fixed;top:1.5rem;left:1.5rem;z-index:100;">
    <img src="/images/logo.png" alt="Stratix" style="height:180px;width:auto;">
</div>

<div class="d-flex align-items-center justify-content-center min-vh-100 p-3">
    <div style="width:100%; max-width: 520px; margin: 1.5rem;">
        <div class="verify-card p-4 p-md-5" style="text-align: center;">
            
          
            {% for msg in app.flashes('danger') %}
                <div class="alert alert-custom mb-3 d-flex align-items-center gap-2">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>{{ msg }}</span>
                </div>
            {% endfor %}

            <div class="icon-wrapper">
                <i class="bi bi-envelope-paper-fill"></i>
            </div>

            <h2 class="fw-bold mb-2" style="color: #0F172A; font-size: 1.8rem; letter-spacing: -0.02em;">Vérifiez votre email</h2>
            <p class="text-secondary mb-4" style="font-size: 0.9rem; line-height: 1.6;">
                Un lien de réinitialisation a été envoyé à votre adresse email.<br>
                Ce lien expire dans <strong style="color: #0F172A;">1 heure</strong>.
            </p>

            <a href="{{ path('app_login') }}" class="btn-outline-elegant">
                <i class="bi bi-arrow-left"></i> Retour à la connexion
            </a>
        </div>
    </div>
</div>

</body>
</html>