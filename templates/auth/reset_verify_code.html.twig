{% extends 'base_auth.html.twig' %}
{% block title %}Vérification du code{% endblock %}

{% block body %}
<div style="position:fixed;top:1.5rem;left:1.5rem;z-index:100;">
    <img src="/images/logo.png" alt="Stratix" style="height:180px;width:auto;">
</div>
<div class="d-flex align-items-center justify-content-center min-vh-100 bg-white">
    <div style="position:relative;width:100%;max-width:480px;padding:2rem;margin:1.5rem;">
        <div style="position:absolute;top:8px;left:8px;right:-8px;bottom:-8px;background:#e9ecef;border-radius:16px;z-index:0;"></div>
        <div style="position:relative;z-index:1;background:#fff;border-radius:16px;padding:3rem;box-shadow:0 2px 12px rgba(0,0,0,.08);">
            <div class="text-center mb-4">
                <div style="width:64px;height:64px;background:#e0f2fe;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
                    <i class="ti ti-mail-check" style="font-size:2rem;color:#2196f3;"></i>
                </div>
                <h2 class="fw-bold mb-1" style="color:#2196f3;font-size:1.8rem;">Entrez le code</h2>
                <p class="text-secondary">Code envoyé à <strong>{{ email }}</strong></p>
            </div>

            {% if error %}
                <div class="alert alert-danger py-2 small text-center">{{ error }}</div>
            {% endif %}

            <form method="post">
                <div class="mb-4">
                    <input type="text" name="code" maxlength="6" pattern="\d{6}"
                           class="form-control form-control-lg text-center fw-bold"
                           style="font-size:2rem;letter-spacing:.5rem;"
                           placeholder="000000" required autofocus>
                </div>
                <button type="submit" class="btn btn-primary w-100 fw-bold btn-lg">Vérifier</button>
            </form>
            <p class="text-center text-secondary mt-4 mb-0 small">
                <a href="{{ path('app_forgot_password') }}" class="text-primary fw-semibold text-decoration-none">← Renvoyer le code</a>
            </p>
        </div>
    </div>
</div>
{% endblock %}
