{% extends 'base_auth.html.twig' %}
{% block title %}Mot de passe oublié{% endblock %}

{% block body %}
<div style="position:fixed;top:1.5rem;left:1.5rem;z-index:100;">
    <img src="/images/logo.png" alt="Stratix" style="height:180px;width:auto;">
</div>
<div class="d-flex align-items-center justify-content-center min-vh-100 bg-white">
    <div style="position:relative;width:100%;max-width:480px;padding:2rem;margin:1.5rem;">
        <div style="position:absolute;top:8px;left:8px;right:-8px;bottom:-8px;background:#e9ecef;border-radius:16px;z-index:0;"></div>
        <div style="position:relative;z-index:1;background:#fff;border-radius:16px;padding:3rem;box-shadow:0 2px 12px rgba(0,0,0,.08);">
            <h2 class="fw-bold mb-1" style="color:#2196f3;font-size:1.8rem;">Mot de passe oublié ?</h2>
            <p class="text-secondary mb-4">Entrez votre email pour recevoir un code de réinitialisation</p>

            {% for msg in app.flashes('success') %}
                <div class="alert alert-success py-2 small">{{ msg }}</div>
            {% endfor %}

            <form method="post">
                <div class="mb-4">
                    <label class="form-label fw-semibold">Email</label>
                    <input type="email" name="email" class="form-control form-control-lg" placeholder="votre@email.com" required autofocus>
                </div>
                <button type="submit" class="btn btn-primary w-100 fw-bold btn-lg">Envoyer le code</button>
            </form>
            <p class="text-center text-secondary mt-4 mb-0">
                <a href="{{ path('app_login') }}" class="text-primary fw-semibold text-decoration-none">← Retour à la connexion</a>
            </p>
        </div>
    </div>
</div>
{% endblock %}
